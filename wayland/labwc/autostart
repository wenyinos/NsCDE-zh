#!/bin/sh

# Don't use 'set -e' here - optional component failures should not
# kill the entire session. Individual commands handle their own errors.
set -u

nscde_data=${NSCDE_WAYLAND_DATA:-/usr/share/nscde-wayland}
nscde_assets=${NSCDE_WAYLAND_ASSETS:-"$nscde_data/assets"}
wallpaper="$nscde_assets/photos/Flower.png"
scale_file=${NSCDE_WAYLAND_SCALE_FILE:-"${NSCDE_WAYLAND_CONFIG:-"$HOME/.config/nscde-wayland"}/scale"}

# Run command with error handling, logging failures but not stopping
_run() {
	"$@" 2>/dev/null || true
}

apply_global_scale() {
	scale=${NSCDE_WAYLAND_SCALE:-}
	if [ -z "$scale" ] && [ -r "$scale_file" ]; then
		IFS= read -r scale < "$scale_file" || scale=
	fi
	case "$scale" in
		""|*[!0123456789.]*|.*|*.*.*) return ;;
	esac
	command -v wlr-randr >/dev/null 2>&1 || return
	wlr-randr 2>/dev/null | while IFS= read -r line; do
		case "$line" in ""|" "*) continue ;; esac
		output=${line%% *}
		[ -n "$output" ] && wlr-randr --output "$output" --scale "$scale" >/dev/null 2>&1
	done
}

# Start notification daemon
if command -v fnott >/dev/null 2>&1; then
	(nscde-wayland-run fnott &) 2>/dev/null || true
fi

# Start display configuration manager
if command -v kanshi >/dev/null 2>&1; then
	(kanshi &) 2>/dev/null || true
fi

# Apply output scaling
if [ -n "${NSCDE_WAYLAND_SCALE:-}" ] || [ -r "$scale_file" ]; then
	(sleep 1; apply_global_scale) &
fi

# Start panel (prefer native nscde-panel, fallback to sfwbar)
if command -v nscde-panel >/dev/null 2>&1; then
	(nscde-wayland-run nscde-panel &) 2>/dev/null || true
elif command -v sfwbar >/dev/null 2>&1; then
	(nscde-wayland-run sfwbar &) 2>/dev/null || true
fi

# Start application launcher dock
if command -v lavalauncher >/dev/null 2>&1; then
	(nscde-wayland-run app lavalauncher &) 2>/dev/null || true
fi

# Set wallpaper (per-output if outputs.conf exists, else uniform)
outputs_conf=${NSCDE_WAYLAND_CONFIG:-"$HOME/.config/nscde-wayland"}/outputs.conf
if [ -f "$outputs_conf" ] && command -v swaybg >/dev/null 2>&1; then
	swaybg_args=""
	while IFS='=' read -r key val; do
		case "$key" in ''|\#*) continue ;; esac
		img="${val%%:*}"
		mode="${val#*:}"
		[ "$mode" = "$val" ] && mode=fill
		[ -f "$img" ] || continue
		swaybg_args="$swaybg_args -o $key -i $img -m $mode"
	done < "$outputs_conf"
	if [ -n "$swaybg_args" ]; then
		(eval "swaybg $swaybg_args" &) 2>/dev/null || true
	elif [ -f "$wallpaper" ]; then
		(swaybg -i "$wallpaper" -m fill &) 2>/dev/null || true
	fi
elif [ -f "$wallpaper" ]; then
	if command -v swaybg >/dev/null 2>&1; then
		(swaybg -i "$wallpaper" -m fill &) 2>/dev/null || true
	elif command -v wbg >/dev/null 2>&1; then
		(wbg "$wallpaper" &) 2>/dev/null || true
	fi
fi
