#!/usr/bin/env python3
"""
nscde-panel - Native CDE-style front panel for NsCDE Wayland
Uses GTK3 + gtk-layer-shell for Wayland panel implementation.

Usage:
  nscde-panel [--palette PALETTE.dp] [--position top|bottom]
"""

import sys
import os
import signal
import argparse
import subprocess
import json
import threading
from datetime import datetime
from pathlib import Path

import gi
gi.require_version('Gtk', '3.0')
gi.require_version('GtkLayerShell', '0.1')
from gi.repository import Gtk, Gdk, GLib, GtkLayerShell

# Constants
PANEL_HEIGHT = 58
ICON_SIZE = 22
BUTTON_PADDING = 4
CLOCK_FORMAT = "%H:%M"
DATE_FORMAT = "%Y-%m-%d"
NUM_WORKSPACES = 4

# Subpanel definitions (CDE-style)
SUBPANELS = {
