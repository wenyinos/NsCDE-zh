#!/usr/bin/env python3
"""
nscde-wayland-colorcalc - Calculate Motif/CDE colors from palette file
Outputs KEY=VALUE pairs for shell eval.

Usage: nscde-wayland-colorcalc PALETTE.dp [ncolors]
  ncolors: 4 or 8 (default: 8)
"""

import sys
import re

# Motif color calculation constants (from NsCDE MotifColors.py)
XmRED_LUMINOSITY = 0.30
XmGREEN_LUMINOSITY = 0.59
XmBLUE_LUMINOSITY = 0.11
XmINTENSITY_FACTOR = 75
XmLIGHT_FACTOR = 0
XmLUMINOSITY_FACTOR = 25
XmMAX_SHORT = 65535
XmDEFAULT_DARK_THRESHOLD = 20
XmDEFAULT_LIGHT_THRESHOLD = 93
XmDEFAULT_FOREGROUND_THRESHOLD = 70
XmCOLOR_PERCENTILE = XmMAX_SHORT / 100
XmCOLOR_LITE_THRESHOLD = XmDEFAULT_LIGHT_THRESHOLD * XmCOLOR_PERCENTILE
XmCOLOR_DARK_THRESHOLD = XmDEFAULT_DARK_THRESHOLD * XmCOLOR_PERCENTILE
XmFOREGROUND_THRESHOLD = XmDEFAULT_FOREGROUND_THRESHOLD * XmCOLOR_PERCENTILE

XmCOLOR_LITE_SEL_FACTOR = 15
XmCOLOR_LITE_BS_FACTOR = 40
XmCOLOR_LITE_TS_FACTOR = 20
XmCOLOR_LO_SEL_FACTOR = 15
XmCOLOR_LO_BS_FACTOR = 60
XmCOLOR_LO_TS_FACTOR = 50
XmCOLOR_HI_SEL_FACTOR = 15
XmCOLOR_HI_BS_FACTOR = 40
XmCOLOR_HI_TS_FACTOR = 60
XmCOLOR_DARK_SEL_FACTOR = 15
XmCOLOR_DARK_BS_FACTOR = 30
XmCOLOR_DARK_TS_FACTOR = 50


def encode16bpp(color):
    """Convert #RRGGBB to #RRRRGGGGBBBB format"""
    m = re.search(r'#([0-9a-fA-F]{2})([0-9a-fA-F]{2})([0-9a-fA-F]{2})$', color)
    if m:
        a, b, c = m.group(1), m.group(2), m.group(3)
        return f'#{a}{a}{b}{b}{c}{c}'
    m = re.search(r'#[0-9a-fA-F]{12}$', color)
    if m:
        return color
    return '#888888888888'


def bbp_to_rgb(hexcolor):
    """Convert 16-bit hex color to [R, G, B] array"""
    m = re.search(r'#(....)(....)(....)', hexcolor)
    if m:
        return [int(m.group(1), 16), int(m.group(2), 16), int(m.group(3), 16)]
    m = re.search(r'#(..)(..)(..)', hexcolor)
    if m:
        return [int(m.group(1), 16), int(m.group(2), 16), int(m.group(3), 16)]
    return [0, 0, 0]


def brightness(color):
    """Calculate brightness of an RGB color"""
    red, green, blue = color[0], color[1], color[2]
    intensity = (red + green + blue) / 3.0
    luminosity = int(XmRED_LUMINOSITY * red + XmGREEN_LUMINOSITY * green + XmBLUE_LUMINOSITY * blue)
    ma = max(red, green, blue)
    mi = min(red, green, blue)
    light = (mi + ma) / 2.0
    return (intensity * XmINTENSITY_FACTOR + light * XmLIGHT_FACTOR + luminosity * XmLUMINOSITY_FACTOR) / 100.0


def calculate_dark(bg_color):
    """Calculate colors for dark background"""
    fg_color = [0, 0, 0]
    sel_color = [0, 0, 0]
    bs_color = [0, 0, 0]
    ts_color = [0, 0, 0]
    if brightness(bg_color) > XmFOREGROUND_THRESHOLD:
        fg_color = [0, 0, 0]
    else:
        fg_color = [XmMAX_SHORT, XmMAX_SHORT, XmMAX_SHORT]
    for i in range(3):
        sel_color[i] = bg_color[i] + XmCOLOR_DARK_SEL_FACTOR * (XmMAX_SHORT - bg_color[i]) / 100.0
        bs_color[i] = bg_color[i] + XmCOLOR_DARK_BS_FACTOR * (XmMAX_SHORT - bg_color[i]) / 100.0
        ts_color[i] = bg_color[i] + XmCOLOR_DARK_TS_FACTOR * (XmMAX_SHORT - bg_color[i]) / 100.0
    return fg_color, sel_color, bs_color, ts_color


def calculate_light(bg_color):
    """Calculate colors for light background"""
    fg_color = [0, 0, 0]
    sel_color = [0, 0, 0]
    bs_color = [0, 0, 0]
    ts_color = [0, 0, 0]
    if brightness(bg_color) > XmFOREGROUND_THRESHOLD:
        fg_color = [0, 0, 0]
    else:
        fg_color = [XmMAX_SHORT, XmMAX_SHORT, XmMAX_SHORT]
    for i in range(3):
        sel_color[i] = bg_color[i] - (bg_color[i] * XmCOLOR_LITE_SEL_FACTOR) / 100.0
        bs_color[i] = bg_color[i] - (bg_color[i] * XmCOLOR_LITE_BS_FACTOR) / 100.0
        ts_color[i] = bg_color[i] - (bg_color[i] * XmCOLOR_LITE_TS_FACTOR) / 100.0
    return fg_color, sel_color, bs_color, ts_color


def calculate_medium(bg_color):
    """Calculate colors for medium background"""
    fg_color = [0, 0, 0]
    sel_color = [0, 0, 0]
    bs_color = [0, 0, 0]
    ts_color = [0, 0, 0]
    b = brightness(bg_color)
    if b > XmFOREGROUND_THRESHOLD:
        fg_color = [0, 0, 0]
    else:
        fg_color = [XmMAX_SHORT, XmMAX_SHORT, XmMAX_SHORT]
    f_sel = XmCOLOR_LO_SEL_FACTOR + (b * (XmCOLOR_HI_SEL_FACTOR - XmCOLOR_LO_SEL_FACTOR) / XmMAX_SHORT)
    f_bs = XmCOLOR_LO_BS_FACTOR + (b * (XmCOLOR_HI_BS_FACTOR - XmCOLOR_LO_BS_FACTOR) / XmMAX_SHORT)
    f_ts = XmCOLOR_LO_TS_FACTOR + (b * (XmCOLOR_HI_TS_FACTOR - XmCOLOR_LO_TS_FACTOR) / XmMAX_SHORT)
    for i in range(3):
        sel_color[i] = bg_color[i] - (bg_color[i] * f_sel) / 100.0
        bs_color[i] = bg_color[i] - (bg_color[i] * f_bs) / 100.0
        ts_color[i] = bg_color[i] + f_ts * (XmMAX_SHORT - bg_color[i]) / 100.0
    return fg_color, sel_color, bs_color, ts_color


def rgb_to_hex(rgb):
    """Convert [R, G, B] array to #rrggbb hex string"""
    def to_hex(n):
        n = max(0, min(65535, int(n)))
        # Convert 16-bit to 8-bit
        v = n >> 8
        return format(v, '02x')
    return f'#{to_hex(rgb[0])}{to_hex(rgb[1])}{to_hex(rgb[2])}'


def read_palette(filename):
    """Read palette colors from .dp file"""
    colors = []
    with open(filename, 'r') as f:
        for line in f:
            line = line.strip()
            if line.startswith('#') and len(line) >= 13:
                colors.append(line)
    return colors


def main():
    if len(sys.argv) < 2:
        print("Usage: nscde-wayland-colorcalc PALETTE.dp [ncolors]", file=sys.stderr)
        sys.exit(1)

    palette_file = sys.argv[1]
    ncolors = int(sys.argv[2]) if len(sys.argv) > 2 else 8

    palette = read_palette(palette_file)
    if len(palette) < 7:
        print(f"error: palette must have at least 7 colors, found {len(palette)}", file=sys.stderr)
        sys.exit(1)

    # Calculate colors for each palette entry
    bg = [None] * 9
    fg = [None] * 9
    sel = [None] * 9
    bs = [None] * 9
    ts = [None] * 9

    for i in range(1, 9):
        color16 = encode16bpp(palette[i - 1])
        bg_color = bbp_to_rgb(color16)
        b = brightness(bg_color)
        if b < XmCOLOR_DARK_THRESHOLD:
            fg_c, sel_c, bs_c, ts_c = calculate_dark(bg_color)
        elif b > XmCOLOR_LITE_THRESHOLD:
            fg_c, sel_c, bs_c, ts_c = calculate_light(bg_color)
        else:
            fg_c, sel_c, bs_c, ts_c = calculate_medium(bg_color)
        bg[i] = rgb_to_hex(bg_color)
        fg[i] = rgb_to_hex(fg_c)
        sel[i] = rgb_to_hex(sel_c)
        bs[i] = rgb_to_hex(bs_c)
        ts[i] = rgb_to_hex(ts_c)

    # 4-color mode: copy color 2 to 5, 6, 7, 8
    if ncolors == 4:
        for idx in [5, 6, 7, 8]:
            bg[idx] = bg[2]
            fg[idx] = fg[2]
            sel[idx] = sel[2]
            bs[idx] = bs[2]
            ts[idx] = ts[2]

    # Output as shell-evaluable KEY=VALUE pairs
    for i in range(1, 9):
        print(f'NSCDE_BG_COLOR_{i}={bg[i]}')
        print(f'NSCDE_FG_COLOR_{i}={fg[i]}')
        print(f'NSCDE_TS_COLOR_{i}={ts[i]}')
        print(f'NSCDE_BS_COLOR_{i}={bs[i]}')
        print(f'NSCDE_SEL_COLOR_{i}={sel[i]}')
        # Disabled fg
        fg_r = int(fg[i][1:3], 16)
        fg_g = int(fg[i][3:5], 16)
        fg_b = int(fg[i][5:7], 16)
        bg_r = int(bg[i][1:3], 16)
        bg_g = int(bg[i][3:5], 16)
        bg_b = int(bg[i][5:7], 16)
        dis_r = (fg_r + bg_r) // 2
        dis_g = (fg_g + bg_g) // 2
        dis_b = (fg_b + bg_b) // 2
        print(f'NSCDE_DISABLED_FG_COLOR_{i}=#{dis_r:02x}{dis_g:02x}{dis_b:02x}')


if __name__ == '__main__':
    main()
