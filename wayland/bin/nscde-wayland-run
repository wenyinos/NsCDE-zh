#!/bin/sh

set -eu

cmd=${1:-}
[ -n "$cmd" ] || {
	printf '%s\n' "usage: nscde-wayland-run COMMAND [ARGS...]" >&2
	exit 2
}
shift

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
wayland_dir=$(CDPATH= cd -- "$script_dir/.." && pwd)

if [ -n "${NSCDE_WAYLAND_SOURCE:-}" ]; then
	source_dir=$NSCDE_WAYLAND_SOURCE
elif [ -d "$wayland_dir/labwc" ]; then
	source_dir=$wayland_dir
elif [ -d "/usr/local/share/nscde-wayland" ]; then
	source_dir=/usr/local/share/nscde-wayland
else
	source_dir=/usr/share/nscde-wayland
fi

asset_source=${NSCDE_WAYLAND_ASSET_SOURCE:-"$source_dir/assets"}
config_root=${NSCDE_WAYLAND_CONFIG:-"${XDG_CONFIG_HOME:-"$HOME/.config"}/nscde-wayland"}
app_config_home=${NSCDE_WAYLAND_APP_CONFIG_HOME:-"$config_root/app-config"}
app_data_home=${NSCDE_WAYLAND_APP_DATA_HOME:-"${XDG_DATA_HOME:-"$HOME/.local/share"}/nscde-wayland/app-data"}
base_config_dirs=${NSCDE_BASE_XDG_CONFIG_DIRS:-${XDG_CONFIG_DIRS:-/etc/xdg}}
base_data_dirs=${NSCDE_BASE_XDG_DATA_DIRS:-${XDG_DATA_DIRS:-/usr/local/share:/usr/share}}
nscde_data_dirs="$source_dir:$asset_source/xdg:$base_data_dirs"

ensure_app_config() {
	gtk_theme=${NSCDE_WAYLAND_GTK_THEME:-NsCDE}
	qt_style=${NSCDE_WAYLAND_QT_STYLE:-kvantum}
	filemgr_desktop=${NSCDE_WAYLAND_FILEMGR_DESKTOP:-pcmanfm-qt.desktop}
	mkdir -p "$app_config_home/gtk-3.0" "$app_config_home/gtk-4.0" \
		"$app_config_home/qt5ct" "$app_config_home/qt6ct" \
		"$app_config_home/Kvantum" "$app_config_home/pcmanfm-qt" \
		"$app_data_home/applications"
	for gtkver in gtk-3.0 gtk-4.0; do
		if [ ! -e "$app_config_home/$gtkver/settings.ini" ]; then
			cat > "$app_config_home/$gtkver/settings.ini" <<EOF
[Settings]
gtk-theme-name=$gtk_theme
gtk-icon-theme-name=NsCDE
gtk-cursor-theme-name=NsCDE
gtk-font-name=Noto Sans CJK SC 10
EOF
		fi
	done
	for qtver in qt5ct qt6ct; do
		if [ ! -e "$app_config_home/$qtver/${qtver}.conf" ]; then
			printf '%s\n' \
				"[Appearance]" \
				"icon_theme=NsCDE" \
				"standard_dialogs=default" \
				"style=$qt_style" \
				"" \
				"[Fonts]" \
				'fixed="Noto Sans Mono CJK SC,10"' \
				'general="Noto Sans CJK SC,10"' \
				> "$app_config_home/$qtver/${qtver}.conf"
		fi
	done
	if [ ! -e "$app_config_home/Kvantum/kvantum.kvconfig" ]; then
		printf '[General]\ntheme=NsCDE\n' > "$app_config_home/Kvantum/kvantum.kvconfig"
	fi
	if [ ! -e "$app_config_home/kdeglobals" ]; then
		printf '[Icons]\nTheme=NsCDE\n' > "$app_config_home/kdeglobals"
	fi
	if [ ! -e "$app_config_home/mimeapps.list" ]; then
		printf '[Default Applications]\ninode/directory=%s\n' "$filemgr_desktop" > "$app_config_home/mimeapps.list"
	fi
	if [ ! -e "$app_config_home/pcmanfm-qt/pcmanfm-qt.conf" ]; then
		printf '%s\n' \
			"[General]" \
			"Terminal=foot" \
			"SuCommand=" \
			"Archiver=file-roller" \
			"SiUnit=false" \
			"" \
			"[Desktop]" \
			"ShowDesktop=false" \
			> "$app_config_home/pcmanfm-qt/pcmanfm-qt.conf"
	fi
}

case "$cmd" in
	fuzzel)
		XDG_CONFIG_DIRS=$base_config_dirs XDG_DATA_DIRS=$nscde_data_dirs exec fuzzel \
			--config="$source_dir/fuzzel/fuzzel.ini" \
			--icon-theme=NsCDE "$@"
		;;
	foot)
		XDG_CONFIG_DIRS=$base_config_dirs XDG_DATA_DIRS=$base_data_dirs exec foot \
			--config="$source_dir/foot/foot.ini" "$@"
		;;
	fnott)
		XDG_CONFIG_DIRS=$base_config_dirs XDG_DATA_DIRS=$nscde_data_dirs exec fnott \
			-c "$source_dir/fnott/fnott.ini" "$@"
		;;
	nscde-panel)
		NSCDE_BASE_XDG_DATA_DIRS=$base_data_dirs \
			XDG_DATA_DIRS=$nscde_data_dirs exec nscde-panel "$@"
		;;
	sfwbar)
		NSCDE_BASE_XDG_DATA_DIRS=$base_data_dirs \
			XDG_DATA_DIRS=$nscde_data_dirs exec sfwbar "$@"
		;;
	app)
		[ "$#" -gt 0 ] || {
			printf '%s\n' "usage: nscde-wayland-run app COMMAND [ARGS...]" >&2
			exit 2
		}
		ensure_app_config
		gtk2rc=$asset_source/integration/gtk2_gtk3_qt/gtk-2.0/gtkrc
		[ ! -r "$gtk2rc" ] || export GTK2_RC_FILES=$gtk2rc
		export XDG_CONFIG_HOME=$app_config_home
		export XDG_DATA_HOME=$app_data_home
		export XDG_CONFIG_DIRS=$base_config_dirs
		export XDG_DATA_DIRS=$nscde_data_dirs
		export GTK_THEME=${NSCDE_WAYLAND_GTK_THEME:-NsCDE}
		export QT_QPA_PLATFORMTHEME=${NSCDE_WAYLAND_QT_PLATFORMTHEME:-qt5ct}
		export XCURSOR_THEME=${NSCDE_WAYLAND_CURSOR_THEME:-NsCDE}
		exec "$@"
		;;
	*)
		printf '%s\n' "unknown command: $cmd" >&2
		exit 2
		;;
esac
