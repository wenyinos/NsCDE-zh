#!/usr/bin/env python3
"""
nscde-panel - Native CDE-style front panel for NsCDE Wayland
Uses PyQt6 for Wayland panel implementation.

Usage:
  nscde-panel [--palette PALETTE.dp] [--position top|bottom]
"""

import sys
import os
import signal
import argparse
from datetime import datetime

from PyQt6.QtWidgets import (
    QApplication, QWidget, QHBoxLayout, QVBoxLayout,
    QPushButton, QLabel, QDialog, QMenu
)
from PyQt6.QtCore import (
    Qt, QTimer, QProcess, QPoint, QSize
)
from PyQt6.QtGui import (
    QIcon, QScreen, QFont
)

# Constants
PANEL_HEIGHT = 58
ICON_SIZE = 22
BUTTON_PADDING = 4
CLOCK_FORMAT = "%H:%M"
DATE_FORMAT = "%Y-%m-%d"
NUM_WORKSPACES = 4

# Subpanel definitions (CDE-style)
SUBPANELS = {
    "utilities-terminal": {
        "title": "Terminal Tools",
        "items": [
            {"name": "Terminal", "icon": "utilities-terminal", "cmd": ["nscde-wayland-run", "foot"]},
            {"name": "Screenshot Area", "icon": "camera-photo", "cmd": ["nscde-wayland-screenshot", "area"]},
            {"name": "Screenshot Full", "icon": "camera-photo", "cmd": ["nscde-wayland-screenshot", "full"]},
        ]
    },
    "system-file-manager": {
        "title": "File Tools",
        "items": [
            {"name": "File Manager", "icon": "system-file-manager", "cmd": ["nscde-wayland-run", "app", "pcmanfm-qt"]},
            {"name": "Disks", "icon": "drive-harddisk", "cmd": ["nscde-wayland-run", "app", "gnome-disks"]},
        ]
    },
    "start-here": {
        "title": "NsCDE Menu",
        "items": [
            {"name": "Run...", "icon": "system-run", "cmd": ["nscde-wayland-run", "fuzzel"]},
            {"name": "Terminal", "icon": "utilities-terminal", "cmd": ["nscde-wayland-run", "foot"]},
            {"name": "File Manager", "icon": "system-file-manager", "cmd": ["nscde-wayland-run", "app", "pcmanfm-qt"]},
            {"name": "Settings", "icon": "preferences-system", "cmd": ["nscde-wayland-run", "app", "nwg-look"]},
            {"name": "Screenshot", "icon": "camera-photo", "cmd": ["nscde-wayland-screenshot", "area"]},
            {"name": "Reconfigure", "icon": "view-refresh", "cmd": ["nscde-wayland-run", "labwc", "-a", "Reconfigure"]},
            {"name": "Exit", "icon": "system-log-out", "cmd": ["nscde-wayland-run", "labwc", "-a", "Exit"]},
        ]
    },
}


def find_default_palette():
    """Find default palette file"""
    for path in [
        os.path.expanduser("~/.config/nscde-wayland/palette.dp"),
        os.path.expanduser("~/.NsCDE/palettes/GrayScale.dp"),
        "/usr/local/share/nscde-wayland/assets/palettes/GrayScale.dp",
        "/usr/share/nscde-wayland/assets/palettes/GrayScale.dp",
    ]:
        if os.path.exists(path):
            return path
    return None


def load_palette_colors(palette_file=None):
    """Load colors from CDE palette file via colorcalc"""
    colors = {
        'bg': '#b8b8b8', 'fg': '#000000', 'ts': '#ffffff',
        'bs': '#5f5f5f', 'sel': '#9fb4cf', 'btn_bg': '#c7c7c7',
        'btn_ts': '#ffffff', 'btn_bs': '#5a5a5a',
    }

    if not palette_file or not os.path.exists(palette_file):
        return colors

    try:
        script_dir = os.path.dirname(os.path.abspath(__file__))
        colorcalc = os.path.join(script_dir, 'nscde-wayland-colorcalc')
        if os.path.exists(colorcalc):
            proc = QProcess()
            proc.start(colorcalc, [palette_file, '8'])
            if proc.waitForFinished(3000):
                output = bytes(proc.readAllStandardOutput()).decode()
                for line in output.strip().split('\n'):
                    if '=' in line:
                        key, val = line.split('=', 1)
                        mapping = {
                            'NSCDE_BG_COLOR_5': 'bg', 'NSCDE_FG_COLOR_5': 'fg',
                            'NSCDE_TS_COLOR_5': 'ts', 'NSCDE_BS_COLOR_5': 'bs',
                            'NSCDE_SEL_COLOR_5': 'sel', 'NSCDE_BG_COLOR_1': 'btn_bg',
                            'NSCDE_TS_COLOR_1': 'btn_ts', 'NSCDE_BS_COLOR_1': 'btn_bs',
                        }
                        if key in mapping:
                            colors[mapping[key]] = val
    except Exception as e:
        print(f"Warning: Failed to load palette: {e}", file=sys.stderr)

    return colors


def build_cde_stylesheet(colors):
    """Build CDE 3D border stylesheet from palette colors"""
    return f"""
    QWidget#panelWindow {{
        background-color: {colors['bg']};
        border-top: 2px solid {colors['ts']};
        border-left: 2px solid {colors['ts']};
        border-right: 2px solid {colors['bs']};
        border-bottom: 2px solid {colors['bs']};
    }}
    QPushButton {{
        background-color: {colors['btn_bg']};
        color: {colors['fg']};
        border-top: 2px solid {colors['btn_ts']};
        border-left: 2px solid {colors['btn_ts']};
        border-right: 2px solid {colors['btn_bs']};
        border-bottom: 2px solid {colors['btn_bs']};
        border-radius: 0px;
        padding: {BUTTON_PADDING}px {BUTTON_PADDING * 2}px;
        margin: 2px;
        min-width: 28px;
        min-height: 28px;
    }}
    QPushButton:hover {{
        background-color: {colors['sel']};
    }}
    QPushButton:pressed {{
        border-top: 2px solid {colors['btn_bs']};
        border-left: 2px solid {colors['btn_bs']};
        border-right: 2px solid {colors['btn_ts']};
        border-bottom: 2px solid {colors['btn_ts']};
    }}
    QLabel {{
        color: {colors['fg']};
        font: 12px Sans;
    }}
    QLabel#clockLabel {{
        font: bold 12px Sans;
        padding: 0 8px;
    }}
    QLabel#dateLabel {{
        font: 11px Sans;
        padding: 0 8px;
    }}
    QPushButton#taskbarBtn {{
        min-width: 100px;
        padding: 3px 8px;
    }}
    QPushButton#taskbarBtn:checked {{
        background-color: {colors['sel']};
    }}
    QPushButton#workspaceBtn {{
        min-width: 28px;
        padding: 2px 6px;
    }}
    QPushButton#workspaceBtn:checked {{
        background-color: {colors['sel']};
    }}
    QPushButton#launcherBtn {{
        min-width: 42px;
    }}
    """


# GUI application applications for taskbar tracking
GUI_APPS = {
    "foot": "utilities-terminal",
    "pcmanfm-qt": "system-file-manager",
    "firefox": "firefox",
    "thunderbird": "thunderbird",
    "nautilus": "system-file-manager",
    "dolphin": "system-file-manager",
    "konsole": "utilities-terminal",
    "gnome-terminal": "utilities-terminal",
    "kate": "text-editor",
    "gedit": "text-editor",
    "vim": "text-editor",
    "nvim": "text-editor",
    "code": "visual-studio-code",
    "sublime_text": "text-editor",
}


def enumerate_windows():
    """Enumerate GUI windows by scanning /proc"""
    windows = []
    seen = set()
    try:
        for pid in os.listdir('/proc'):
            if not pid.isdigit():
                continue
            try:
                with open(f'/proc/{pid}/comm') as f:
                    comm = f.read().strip()
                if comm in GUI_APPS and comm not in seen:
                    seen.add(comm)
                    windows.append({
                        "id": pid,
                        "name": comm,
                        "icon": GUI_APPS.get(comm, "application-x-executable")
                    })
            except (PermissionError, FileNotFoundError, ProcessLookupError):
                continue
    except Exception:
        pass
    return windows


class SubPanel(QDialog):
    """CDE-style subpanel popup window"""

    def __init__(self, parent, items, title):
        super().__init__(parent)
        self.setWindowFlags(
            Qt.WindowType.Popup |
            Qt.WindowType.FramelessWindowHint
        )
        self.setFixedWidth(180)

        colors = parent.colors

        # CDE 3D border
        self.setStyleSheet(f"""
            QDialog {{
                background-color: {colors['bg']};
                border-top: 2px solid {colors['ts']};
                border-left: 2px solid {colors['ts']};
                border-right: 2px solid {colors['bs']};
                border-bottom: 2px solid {colors['bs']};
            }}
            QLabel {{
                color: {colors['fg']};
                font: bold 12px Sans;
                padding: 2px 8px;
            }}
            QPushButton {{
                background-color: {colors['btn_bg']};
                color: {colors['fg']};
                border-top: 2px solid {colors['btn_ts']};
                border-left: 2px solid {colors['btn_ts']};
                border-right: 2px solid {colors['btn_bs']};
                border-bottom: 2px solid {colors['btn_bs']};
                border-radius: 0px;
                padding: 4px 8px;
                margin: 1px;
                min-width: 160px;
                text-align: left;
            }}
            QPushButton:hover {{
                background-color: {colors['sel']};
            }}
            QPushButton:pressed {{
                border-top: 2px solid {colors['btn_bs']};
                border-left: 2px solid {colors['btn_bs']};
                border-right: 2px solid {colors['btn_ts']};
                border-bottom: 2px solid {colors['btn_ts']};
            }}
        """)

        vbox = QVBoxLayout(self)
        vbox.setContentsMargins(4, 4, 4, 4)
        vbox.setSpacing(1)

        # Title
        title_label = QLabel(title)
        vbox.addWidget(title_label)

        # Separator
        sep = QLabel()
        sep.setFixedHeight(2)
        sep.setStyleSheet(f"background-color: {colors['bs']};")
        vbox.addWidget(sep)

        # Menu items
        for item in items:
            btn = QPushButton(item["name"])
            icon = QIcon.fromTheme(item.get("icon", "application-x-executable"))
            if not icon.isNull():
                btn.setIcon(icon)
                btn.setIconSize(QSize(16, 16))
            btn.clicked.connect(lambda checked, cmd=item["cmd"]: self._on_item_clicked(cmd))
            vbox.addWidget(btn)

    def _on_item_clicked(self, cmd):
        """Handle menu item click"""
        try:
            QProcess.startDetached(cmd[0], cmd[1:])
        except Exception as e:
            print(f"Error launching {cmd}: {e}", file=sys.stderr)
        self.accept()

    def popup_at(self, global_pos):
        """Show subpanel at global position, above the panel"""
        self.adjustSize()
        x = global_pos.x()
        y = global_pos.y() - self.height() - 4
        self.move(x, y)
        self.exec()


class CDEPanel(QWidget):
    """Main CDE-style panel widget"""

    def __init__(self, palette_file=None, position='bottom'):
        super().__init__()
        self.palette_file = palette_file or find_default_palette()
        self.position = position
        self.colors = load_palette_colors(self.palette_file)
        self.current_workspace = 0
        self.subpanel = None

        self.setObjectName("panelWindow")
        self.setFixedHeight(PANEL_HEIGHT)

        # Window flags: frameless, stay on top, tool, no focus
        self.setWindowFlags(
            Qt.WindowType.FramelessWindowHint |
            Qt.WindowType.WindowStaysOnTopHint |
            Qt.WindowType.Tool |
            Qt.WindowType.WindowDoesNotAcceptFocus
        )

        # Apply CDE stylesheet
        self.setStyleSheet(build_cde_stylesheet(self.colors))

        # Build UI
        self._build_ui()

        # Position panel
        self._position_panel()

        # Timers
        self.clock_timer = QTimer(self)
        self.clock_timer.timeout.connect(self._update_clock)
        self.clock_timer.start(1000)

        self.taskbar_timer = QTimer(self)
        self.taskbar_timer.timeout.connect(self._update_taskbar)
        self.taskbar_timer.start(2000)

        # Initial update
        self._update_clock()
        self._update_taskbar()

    def _position_panel(self):
        """Position panel at bottom of screen"""
        screen = QApplication.primaryScreen()
        if screen:
            geo = screen.availableGeometry()
            self.setFixedWidth(geo.width())
            if self.position == 'bottom':
                self.move(geo.x(), geo.y() + geo.height() - PANEL_HEIGHT)
            else:
                self.move(geo.x(), geo.y())

    def _build_ui(self):
        """Build the panel UI"""
        hbox = QHBoxLayout(self)
        hbox.setContentsMargins(4, 2, 4, 2)
        hbox.setSpacing(2)

        # Left: Menu + Launchers with subpanels
        left_box = QHBoxLayout()
        left_box.setSpacing(2)
        for icon, tooltip, subpanel_key in [
            ("start-here", "NsCDE Menu", "start-here"),
            ("utilities-terminal", "Terminal Tools", "utilities-terminal"),
            ("system-file-manager", "File Tools", "system-file-manager"),
        ]:
            btn = self._create_button(icon, tooltip)
            btn.setObjectName("launcherBtn")
            btn.clicked.connect(lambda checked, key=subpanel_key: self._on_launcher_clicked(key, btn))
            left_box.addWidget(btn)
        hbox.addLayout(left_box)

        # Workspace switcher
        ws_box = QHBoxLayout()
        ws_box.setSpacing(1)
        self.workspace_buttons = []
        for i in range(NUM_WORKSPACES):
            ws_btn = QPushButton(str(i + 1))
            ws_btn.setObjectName("workspaceBtn")
            ws_btn.setCheckable(True)
            ws_btn.setChecked(i == self.current_workspace)
            ws_btn.clicked.connect(lambda checked, num=i: self._on_workspace_clicked(num))
            ws_box.addWidget(ws_btn)
            self.workspace_buttons.append(ws_btn)
        hbox.addLayout(ws_box)

        # Center: Taskbar
        self.taskbar_box = QHBoxLayout()
        self.taskbar_box.setSpacing(2)
        hbox.addLayout(self.taskbar_box, 1)  # stretch=1

        # Right: Tray + Clock
        right_box = QHBoxLayout()
        right_box.setSpacing(2)

        # System tray placeholder
        self.tray_label = QLabel("⚙")
        self.tray_label.setToolTip("System Tray (SNI)")
        right_box.addWidget(self.tray_label)

        # Date
        self.date_label = QLabel()
        self.date_label.setObjectName("dateLabel")
        right_box.addWidget(self.date_label)

        # Clock
        self.clock_label = QLabel()
        self.clock_label.setObjectName("clockLabel")
        right_box.addWidget(self.clock_label)

        hbox.addLayout(right_box)

        # Initialize system tray
        self._init_system_tray()

    def _init_system_tray(self):
        """Initialize system tray area using QSystemTrayIcon"""
        from PyQt6.QtWidgets import QSystemTrayIcon
        if QSystemTrayIcon.isSystemTrayAvailable():
            self.systray = QSystemTrayIcon(self)
            self.systray.setIcon(QIcon.fromTheme("system-tray-icon", QIcon.fromTheme("application-x-executable")))
            self.systray.setToolTip("NsCDE System Tray")
            self.systray.show()
            # Hide placeholder since we have real systray
            self.tray_label.hide()
        else:
            self.systray = None
            # Update tray label periodically
            self.tray_timer = QTimer(self)
            self.tray_timer.timeout.connect(self._update_tray_label)
            self.tray_timer.start(2000)

    def _create_button(self, icon_name, tooltip):
        """Create a CDE-style button with icon"""
        btn = QPushButton()
        btn.setToolTip(tooltip)
        icon = QIcon.fromTheme(icon_name)
        if not icon.isNull():
            btn.setIcon(icon)
            btn.setIconSize(QSize(ICON_SIZE, ICON_SIZE))
        else:
            btn.setText(tooltip[:2])
        return btn

    def _on_launcher_clicked(self, subpanel_key, button):
        """Handle launcher button click with subpanel"""
        if subpanel_key in SUBPANELS:
            subpanel_def = SUBPANELS[subpanel_key]

            # Close existing subpanel
            if self.subpanel and self.subpanel.isVisible():
                self.subpanel.reject()

            # Create new subpanel
            self.subpanel = SubPanel(self, subpanel_def["items"], subpanel_def["title"])

            # Position relative to button
            global_pos = button.mapToGlobal(QPoint(0, 0))
            self.subpanel.popup_at(global_pos)
        else:
            try:
                QProcess.startDetached("nscde-wayland-run", ["fuzzel"])
            except Exception as e:
                print(f"Error launching fuzzel: {e}", file=sys.stderr)

    def _update_clock(self):
        """Update clock display"""
        now = datetime.now()
        self.clock_label.setText(now.strftime(CLOCK_FORMAT))
        self.date_label.setText(now.strftime(DATE_FORMAT))

    def _update_taskbar(self):
        """Update taskbar with current windows"""
        windows = enumerate_windows()

        # Clear existing buttons
        while self.taskbar_box.count():
            item = self.taskbar_box.takeAt(0)
            widget = item.widget()
            if widget:
                widget.deleteLater()

        if not windows:
            placeholder = QLabel("No windows")
            placeholder.setEnabled(False)
            self.taskbar_box.addWidget(placeholder)
            return

        for win in windows:
            btn = QPushButton(win["name"][:20])
            btn.setObjectName("taskbarBtn")
            btn.setCheckable(True)
            icon = QIcon.fromTheme(win["icon"])
            if not icon.isNull():
                btn.setIcon(icon)
                btn.setIconSize(QSize(16, 16))
            btn.clicked.connect(lambda checked, w=win: self._on_taskbar_clicked(w))
            self.taskbar_box.addWidget(btn)

    def _on_taskbar_clicked(self, window_info):
        """Handle taskbar button click - focus window"""
        # labwc doesn't have direct window focus API
        # Future: use wlr-foreign-toplevel when labwc supports it
        pass

    def _update_tray_label(self):
        """Update tray placeholder label (fallback when no QSystemTrayIcon)"""
        self.tray_label.setText("⚙")
        self.tray_label.setToolTip("System Tray (SNI)")

    def _on_workspace_clicked(self, workspace_num):
        """Handle workspace button click"""
        workspace_name = f"ws{workspace_num + 1}"
        try:
            QProcess.startDetached("nscde-wayland-run", ["labwc", "-a", "GoToDesktop", workspace_name])
        except Exception as e:
            print(f"Error switching workspace: {e}", file=sys.stderr)

        self.current_workspace = workspace_num
        for i, btn in enumerate(self.workspace_buttons):
            btn.setChecked(i == workspace_num)


def main():
    parser = argparse.ArgumentParser(description='NsCDE CDE-style panel (PyQt6)')
    parser.add_argument('--palette', help='Path to CDE palette file')
    parser.add_argument('--position', choices=['top', 'bottom'], default='bottom',
                        help='Panel position (default: bottom)')
    args = parser.parse_args()

    # Enable High DPI
    QApplication.setHighDpiScaleFactorRoundingPolicy(
        Qt.HighDpiScaleFactorRoundingPolicy.PassThrough
    )

    app = QApplication(sys.argv)
    app.setApplicationName("nscde-panel")
    app.setDesktopFileName("nscde-panel")

    # Handle SIGINT/SIGTERM gracefully
    signal.signal(signal.SIGINT, lambda s, f: app.quit())
    signal.signal(signal.SIGTERM, lambda s, f: app.quit())

    panel = CDEPanel(palette_file=args.palette, position=args.position)
    panel.show()

    # Ensure panel stays on top (some composizers need this)
    panel.raise_()
    panel.activateWindow()
    # Re-set no-activate since we only want to raise, not focus
    # (activateWindow may steal focus, but it's needed for z-order)

    sys.exit(app.exec())


if __name__ == '__main__':
    main()
