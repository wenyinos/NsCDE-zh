        self._press_bg = parent.colors.get('sel', '#a0a0a0')
        self.setToolTip(tooltip)
        self.setFixedSize(CENTER_BTN_W, CENTER_BTN_H)
        self.setContentsMargins(0, 0, 0, 0)

        icon_path = get_icon_path(xpm_icon_name)
        if icon_path:
            self._pixmap = QPixmap(icon_path)
            if not self._pixmap.isNull():
                self.setIcon(QIcon(self._pixmap))
                self.setIconSize(QSize(20, 20))

        self._update_style(pressed=False)

    def _update_style(self, pressed=False):
        c = self._colors
        if pressed:
            self.setStyleSheet(f"""
                QPushButton {{
                    background-color: {self._press_bg};
                    border: none;
                    border-radius: 0px;
                    padding: 0px;
                    margin: 0px;
                }}
            """)
        else:
            self.setStyleSheet(f"""
                QPushButton {{
                    background-color: {c['bg']};
                    border: none;
                    border-radius: 0px;
                    padding: 0px;
                    margin: 0px;
                }}
            """)

    def mousePressEvent(self, event):
        self._update_style(pressed=True)
        super().mousePressEvent(event)

    def mouseReleaseEvent(self, event):
        self._update_style(pressed=False)
        super().mouseReleaseEvent(event)


class HandleWidget(QWidget):
    """CDE Front Panel handle widget (FpHandle.xpm).
    Matches original: 19x63, Frame 0, Icon NsCDE/FpHandle.xpm
    Handle uses CS23 (panel) background color.
    """

    def __init__(self, parent, width=19, height=63):
        super().__init__(parent)
        self._colors = parent.colors
        self.setFixedSize(width, height)
        self.setToolTip("Drag to move panel")

        icon_path = get_icon_path("FpHandle.xpm")
        if icon_path:
            self._pixmap = QPixmap(icon_path)
            if not self._pixmap.isNull():
                label = QLabel(self)
                label.setPixmap(self._pixmap.scaled(width, height - 4,
                                                     Qt.AspectRatioMode.KeepAspectRatio,
                                                     Qt.TransformationMode.SmoothTransformation))
                label.setAlignment(Qt.AlignmentFlag.AlignCenter)
                label.setStyleSheet("background: transparent;")

        self.setStyleSheet(f"background-color: {parent.colors['bg']};")


class CDEPanel(QWidget):
    """Main CDE-style panel widget.
    Layout matches NsCDE FrontPanel.fvwm3.fvwmconf:
      [LeftHandle] [LeftLaunchers] [LeftIcons] [Center] [RightLaunchers] [RightIcons] [RightHandle]
    """

    def __init__(self, palette_file=None, position='bottom'):
        super().__init__()
        self.palette_file = palette_file or find_default_palette()
        self.position = position
        self.colors = load_palette_colors(self.palette_file)
        self.current_workspace = 0
        self.subpanel = None

        self.setObjectName("panelWindow")
        self.setFixedHeight(PANEL_HEIGHT)

        # Window flags: frameless, stay on top, tool, no focus
        self.setWindowFlags(
            Qt.WindowType.FramelessWindowHint |
            Qt.WindowType.WindowStaysOnTopHint |
            Qt.WindowType.Tool |
            Qt.WindowType.WindowDoesNotAcceptFocus
        )

        self.setStyleSheet(build_cde_stylesheet(self.colors))

        self._build_ui()
        self._position_panel()

        # Timers
        self.clock_timer = QTimer(self)
        self.clock_timer.timeout.connect(self._update_clock)
        self.clock_timer.start(1000)

        self.taskbar_timer = QTimer(self)
        self.taskbar_timer.timeout.connect(self._update_taskbar)
        self.taskbar_timer.start(2000)

        self._update_clock()
        self._update_taskbar()

    def _position_panel(self):
        """Position panel at bottom of screen, centered like original CDE.
        Original: Geometry 1015x79 centered horizontally at bottom.
        """
        screen = QApplication.primaryScreen()
        if screen:
            geo = screen.availableGeometry()
            # 面板固定宽度 1015 像素，水平居中
            self.setFixedWidth(PANEL_TOTAL_W)
            self.setFixedHeight(PANEL_HEIGHT)
            x = geo.x() + (geo.width() - PANEL_TOTAL_W) // 2
            if self.position == 'bottom':
                y = geo.y() + geo.height() - PANEL_HEIGHT
            else:
                y = geo.y()
            self.move(x, y)

    def _build_ui(self):
        """Build the panel UI matching NsCDE FrontPanel.fvwm3.fvwmconf layout.

        FvwmButtons 布局（1格=1像素）:
          [左把手21px] [左启动器315x16] [左图标315x62] [中心343x78] [右图标315x62] [右启动器315x16] [右把手21px]
          总宽 1015 x 79 像素，水平居中
        """
        hbox = QHBoxLayout(self)
        hbox.setContentsMargins(0, 0, 0, 0)
        hbox.setSpacing(0)

        # ① 左把手容器 (21x79, Frame 1)
        hbox.addWidget(self._build_handle_container(is_left=True))

        # ② 左侧: launcher(315x16) + Frame1容器(icon 315x62)
        left_side = QWidget()
        left_side.setFixedSize(SIDE_W, PANEL_HEIGHT)
        left_vbox = QVBoxLayout(left_side)
        left_vbox.setContentsMargins(0, 0, 0, 0)
        left_vbox.setSpacing(0)
        left_vbox.addLayout(self._build_launcher_row(is_left=True))
        # 图标行 Frame 1 凸起容器 (匹配 FvwmButtons Frame 1)
        left_icon_frame = QWidget()
        left_icon_frame.setObjectName("iconFrame")
        left_icon_frame.setFixedHeight(ICON_H)
        left_icon_frame.setStyleSheet(f"""
            QWidget#iconFrame {{
                background-color: {self.colors['bg']};
                border-top: 1px solid {self.colors['btn_ts']};
                border-left: 1px solid {self.colors['btn_ts']};
                border-right: 1px solid {self.colors['btn_bs']};
                border-bottom: 1px solid {self.colors['btn_bs']};
            }}
        """)
        left_icon_frame.setLayout(self._build_icon_row(is_left=True))
        left_vbox.addWidget(left_icon_frame)
        hbox.addWidget(left_side)

        # ③ 中心: Lock + WSM + Lite + Exit (343x78)
        hbox.addWidget(self._build_center_section())

        # ④ 右侧: Frame1容器(icon 315x62) + launcher(315x16)
        right_side = QWidget()
        right_side.setFixedSize(SIDE_W, PANEL_HEIGHT)
        right_vbox = QVBoxLayout(right_side)
        right_vbox.setContentsMargins(0, 0, 0, 0)
        right_vbox.setSpacing(0)
        # 图标行 Frame 1 凸起容器 (匹配 FvwmButtons Frame 1)
        right_icon_frame = QWidget()
        right_icon_frame.setObjectName("iconFrame")
        right_icon_frame.setFixedHeight(ICON_H)
        right_icon_frame.setStyleSheet(f"""
            QWidget#iconFrame {{
                background-color: {self.colors['bg']};
                border-top: 1px solid {self.colors['btn_ts']};
                border-left: 1px solid {self.colors['btn_ts']};
                border-right: 1px solid {self.colors['btn_bs']};
                border-bottom: 1px solid {self.colors['btn_bs']};
            }}
        """)
        right_icon_frame.setLayout(self._build_icon_row(is_left=False))
        right_vbox.addWidget(right_icon_frame)
        right_vbox.addLayout(self._build_launcher_row(is_left=False))
        hbox.addWidget(right_side)

        # ⑤ 右把手容器 (21x79, Frame 1)
        hbox.addWidget(self._build_handle_container(is_left=False))

        # 底部 1px 修正线 (Colorset 15 暗线, 匹配 FvwmButtons 底部修正)
        # 从 x=21 到右把手起始位置, y=78 (面板底边)
        bottom_line = QLabel(self)
        bottom_line.setFixedSize(PANEL_TOTAL_W - 42, 1)
        bottom_line.move(HANDLE_WIDTH, PANEL_HEIGHT - 1)
        bottom_line.setStyleSheet(
            f"background-color: {self.colors['gap_lo']}; border: none;"
        )

    def _build_handle_container(self, is_left=True):
        """Build left or right handle container (21x79, Frame 1).
        左: 竖条(1x79,cs14) | Menu(19x14,Frame1,FpMenu.xpm) + gap(19x1,cs14) + Handle(19x63,FpHandle.xpm)
        右: Iconify(20x14,Frame1,FpIconify.xpm) + gap(20x1,cs14) + Handle(20x63,FpHandle.xpm) + 竖条(1x78,cs15)
        """
        container = QWidget()
        container.setFixedSize(HANDLE_WIDTH, PANEL_HEIGHT)
        # Frame 1: 3D raised border using CS1 colors
        container.setStyleSheet(f"""
            QWidget {{
                background-color: {self.colors['bg']};
                border-top: 1px solid {self.colors['btn_ts']};
                border-left: 1px solid {self.colors['btn_ts']};
                border-right: 1px solid {self.colors['btn_bs']};
                border-bottom: 1px solid {self.colors['btn_bs']};
            }}
        """)

        if is_left:
            # 左容器: 竖条 + (Menu + gap + Handle)
            hbox = QHBoxLayout(container)
            hbox.setContentsMargins(0, 0, 0, 0)
            hbox.setSpacing(0)

            # 竖条 1x79 (Colorset 14 = CS1 hi)
            vline = QLabel()
            vline.setFixedSize(1, PANEL_HEIGHT)
            vline.setStyleSheet(f"background-color: {self.colors['gap_hi']}; border: none;")
            hbox.addWidget(vline)

            # 右侧内容区 19x79
            content = QWidget()
            content.setFixedSize(19, 79)
            content.setStyleSheet(f"background-color: {self.colors['bg']};")
            vbox = QVBoxLayout(content)
            vbox.setContentsMargins(0, 0, 0, 0)
            vbox.setSpacing(0)

            # gap H1 (19x1, Colorset 14 = CS1 hi)
            gap1 = QLabel()
            gap1.setFixedSize(19, 1)
            gap1.setStyleSheet(f"background-color: {self.colors['gap_hi']}; border: none;")
            vbox.addWidget(gap1)

            # Menu 按钮 (19x14, Frame 1, FpMenu.xpm)
            menu_btn = QPushButton()
            menu_btn.setFixedSize(19, 14)
            menu_btn.setToolTip("NsCDE Menu")
            icon_path = get_icon_path("FpMenu.xpm")
            if icon_path:
                pm = QPixmap(icon_path)
                if not pm.isNull():
                    menu_btn.setIcon(QIcon(pm))
                    menu_btn.setIconSize(QSize(17, 12))
            menu_btn.setStyleSheet(f"""
                QPushButton {{
                    background-color: {self.colors['btn_bg']};
                    border-top: 1px solid {self.colors['btn_ts']};
                    border-left: 1px solid {self.colors['btn_ts']};
                    border-right: 1px solid {self.colors['btn_bs']};
                    border-bottom: 1px solid {self.colors['btn_bs']};
                    padding: 0px;
                }}
                QPushButton:pressed {{
                    border-top: 1px solid {self.colors['btn_bs']};
                    border-left: 1px solid {self.colors['btn_bs']};
                    border-right: 1px solid {self.colors['btn_ts']};
                    border-bottom: 1px solid {self.colors['btn_ts']};
                }}
            """)
            menu_btn.clicked.connect(lambda: self._on_menu_clicked(menu_btn))
            vbox.addWidget(menu_btn)

            # gap H2 (19x1, Colorset 14 = CS1 hi)
            gap2 = QLabel()
            gap2.setFixedSize(19, 1)
            gap2.setStyleSheet(f"background-color: {self.colors['gap_hi']}; border: none;")
            vbox.addWidget(gap2)

            # Handle (19x63, FpHandle.xpm, Frame 0)
            handle = HandleWidget(self, width=19, height=63)
            vbox.addWidget(handle)

            hbox.addWidget(content)
        else:
            # 右容器: Iconify + gap + Handle + 竖条
            hbox = QHBoxLayout(container)
            hbox.setContentsMargins(0, 0, 0, 0)
            hbox.setSpacing(0)

            # 左侧内容区 20x79
            content = QWidget()
            content.setFixedSize(20, 79)
            content.setStyleSheet(f"background-color: {self.colors['bg']};")
            vbox = QVBoxLayout(content)
            vbox.setContentsMargins(0, 0, 0, 0)
            vbox.setSpacing(0)

            # gap H1 (20x1, Colorset 14 = CS1 hi)
            gap1 = QLabel()
            gap1.setFixedSize(20, 1)
            gap1.setStyleSheet(f"background-color: {self.colors['gap_hi']}; border: none;")
            vbox.addWidget(gap1)

            # Iconify 按钮 (20x14, Frame 1, FpIconify.xpm)
            iconify_btn = QPushButton()
            iconify_btn.setFixedSize(20, 14)
            iconify_btn.setToolTip("Iconify")
            icon_path = get_icon_path("FpIconify.xpm")
            if icon_path:
                pm = QPixmap(icon_path)
                if not pm.isNull():
                    iconify_btn.setIcon(QIcon(pm))
                    iconify_btn.setIconSize(QSize(18, 12))
            iconify_btn.setStyleSheet(f"""
                QPushButton {{
                    background-color: {self.colors['btn_bg']};
                    border-top: 1px solid {self.colors['btn_ts']};
                    border-left: 1px solid {self.colors['btn_ts']};
                    border-right: 1px solid {self.colors['btn_bs']};
                    border-bottom: 1px solid {self.colors['btn_bs']};
                    padding: 0px;
                }}
                QPushButton:pressed {{
                    border-top: 1px solid {self.colors['btn_bs']};
                    border-left: 1px solid {self.colors['btn_bs']};
                    border-right: 1px solid {self.colors['btn_ts']};
                    border-bottom: 1px solid {self.colors['btn_ts']};
                }}
            """)
            iconify_btn.clicked.connect(self._on_iconify_clicked)
            vbox.addWidget(iconify_btn)

            # gap H2 (20x1, Colorset 14 = CS1 hi)
            gap2 = QLabel()
            gap2.setFixedSize(20, 1)
            gap2.setStyleSheet(f"background-color: {self.colors['gap_hi']}; border: none;")
            vbox.addWidget(gap2)

            # Handle (20x63, FpHandle.xpm, Frame 0)
            handle = HandleWidget(self, width=20, height=63)
            vbox.addWidget(handle)

            hbox.addWidget(content)

            # 竖条 1x78 (Colorset 15 = CS1 sh)
            vline = QLabel()
            vline.setFixedSize(1, 78)
            vline.setStyleSheet(f"background-color: {self.colors['gap_lo']}; border: none;")
            hbox.addWidget(vline)

        return container

    def _build_launcher_row(self, is_left=True):
        """Build launcher button row (315x16, 5个按钮水平排列).
        每个按钮 63x16 像素, Frame 1, PressColorset 27.
        """
        hbox = QHBoxLayout()
        hbox.setContentsMargins(0, 0, 0, 0)
        hbox.setSpacing(0)

        if is_left:
            launcher_icons = [
                ("Fpmenu.l.pm", "Applications (L1)"),
                ("Fpterm.l.pm", "Terminal (L2)"),
                ("Fphome.l.pm", "Home (L3)"),
                ("Fpapps.l.pm", "Apps (L4)"),
                ("Fpclock.l.pm", "Clock (L5)"),
            ]
        else:
            launcher_icons = [
                ("Fpprnt.l.pm", "Print (R6)"),
                ("Fpstyle.l.pm", "Style (R7)"),
                ("Fpapps.l.pm", "Apps (R8)"),
                ("Multimedia.l.pm", "Multimedia (R9)"),
                ("Fphelp.l.pm", "Help (R10)"),
            ]

        for icon_name, tooltip in launcher_icons:
            btn = LauncherButton(self, icon_name, tooltip)
            btn.clicked.connect(lambda checked, t=tooltip, b=btn: self._on_launcher_clicked(t, b))
            hbox.addWidget(btn)

        return hbox

    def _build_icon_row(self, is_left=True):
        """Build icon button row (315x62, 5个按钮水平排列).
        每个按钮占 63x62 格子, 48x48 图标居中, Colorset 23, PressColorset 24.
        """
        hbox = QHBoxLayout()
        hbox.setContentsMargins(0, 0, 0, 0)
        hbox.setSpacing(0)

        if is_left:
            icon_defs = [
                ("Fpclock.xpm", "Clock (Btn1)"),
                ("Fpclock.xpm", "Date (Btn2)"),
                ("Fphome.l.pm", "Home (Btn3)"),
                ("Fpterm.l.pm", "Terminal (Btn4)"),
                ("Fpclock.xpm", "Mail (Btn5)"),
            ]
        else:
            icon_defs = [
                ("Fpprnt.l.pm", "Print (Btn6)"),
                ("Fpstyle.l.pm", "Style (Btn7)"),
                ("Fpapps.l.pm", "Apps (Btn8)"),
                ("Multimedia.l.pm", "Multimedia (Btn9)"),
                ("Fphelp.l.pm", "Help (Btn10)"),
            ]

        for icon_name, tooltip in icon_defs:
            btn = IconButton(self, icon_name, tooltip)
            btn.clicked.connect(lambda checked, t=tooltip: self._on_icon_clicked(t))
            hbox.addWidget(btn)

        return hbox

    def _build_center_section(self):
        """Build center section: Lock + PGM + WSM + Lite + Exit (343x78, Frame 1).
        布局匹配原版: Lock(左上) PGM(左下) Lite(右上) Exit(右下) WSM(居中).
        """
        container = QWidget()
        container.setFixedSize(CENTER_W, CENTER_H)
        # Frame 1: 3D raised border using CS1 colors
        container.setStyleSheet(f"""
            background-color: {self.colors['bg']};
            border-top: 1px solid {self.colors['btn_ts']};
            border-left: 1px solid {self.colors['btn_ts']};
            border-right: 1px solid {self.colors['btn_bs']};
            border-bottom: 1px solid {self.colors['btn_bs']};
        """)

        # WSM 主区域 (占满整个容器, 底层)
        wsm_widget = self._build_wsm_widget()
        wsm_widget.setParent(container)
        wsm_widget.move(0, 0)

        # Lock 按钮 (左上角, 44x39, Colorset 23, PressColorset 25)
        lock_btn = CenterButton(self, "FpLock.xpm", "Lock Screen")
        lock_btn.setParent(container)
        lock_btn.move(0, 0)
        lock_btn.clicked.connect(self._on_lock_clicked)

        # PGM 按钮 (左下角, 44x39, Colorset 23, PressColorset 25)
        pgm_btn = CenterButton(self, "Wsm.xpm", "Page Manager")
        pgm_btn.setParent(container)
        pgm_btn.move(0, CENTER_H - CENTER_BTN_H)
        pgm_btn.clicked.connect(self._on_pgm_clicked)

        # Lite 按钮 (右上角, 叠在 WSM 上)
        lite_btn = CenterButton(self, "Fplite.s.pm", "System Load")
        lite_btn.setParent(container)
        lite_btn.move(CENTER_W - CENTER_BTN_W, 0)
        lite_btn.clicked.connect(self._on_lite_clicked)

        # Exit 按钮 (右下角, 叠在 WSM 上)
        exit_btn = CenterButton(self, "FpExit.xpm", "Exit NsCDE")
        exit_btn.setParent(container)
        exit_btn.move(CENTER_W - CENTER_BTN_W, CENTER_H - CENTER_BTN_H)
        exit_btn.clicked.connect(self._on_exit_clicked)

        return container

    def _build_wsm_widget(self):
        """Build workspace manager widget (replaces FvwmScript WSM).
        2x2 网格显示工作区按钮.
        """
        widget = QWidget()
        widget.setFixedSize(CENTER_W, CENTER_H)
        widget.setStyleSheet(f"background-color: {self.colors['bg']};")

        # 标题标签 (Wsm.xpm 图标)
        title = QLabel(widget)
        title.setFixedSize(22, 20)
        title.move(4, 2)
        icon_path = get_icon_path("Wsm.xpm")
        if icon_path:
            pm = QPixmap(icon_path)
            if not pm.isNull():
                title.setPixmap(pm)

        # 2x2 工作区按钮网格
        self.workspace_buttons = []
        grid_x = 4
        grid_y = 24
        for row in range(2):
            for col in range(2):
                idx = row * 2 + col
                ws_btn = QPushButton(str(idx + 1), widget)
                ws_btn.setObjectName("workspaceBtn")
                ws_btn.setCheckable(True)
                ws_btn.setChecked(idx == self.current_workspace)
                ws_btn.setFixedSize(60, 26)
                ws_btn.move(grid_x + col * 64, grid_y + row * 30)
                ws_btn.clicked.connect(lambda checked, num=idx: self._on_workspace_clicked(num))
                self.workspace_buttons.append(ws_btn)

        return widget

    # ============================================================
    # Event handlers
    # ============================================================

    def _on_menu_clicked(self, button):
        """Handle menu button click - show NsCDE root menu"""
        menu = QMenu(self)
        menu.setStyleSheet(f"""
            QMenu {{
                background-color: {self.colors['bg']};
                color: {self.colors['btn_fg']};
                border-top: 2px solid {self.colors['ts']};
                border-left: 2px solid {self.colors['ts']};
                border-right: 2px solid {self.colors['bs']};
                border-bottom: 2px solid {self.colors['bs']};
            }}
            QMenu::item:selected {{
                background-color: {self.colors['sel']};
            }}
        """)

        menu.addAction("Terminal", lambda: QProcess.startDetached("nscde-wayland-run", ["foot"]))
        menu.addAction("File Manager", lambda: QProcess.startDetached("nscde-wayland-run", ["app", "pcmanfm-qt"]))
        menu.addAction("Run...", lambda: QProcess.startDetached("nscde-wayland-run", ["fuzzel"]))
        menu.addSeparator()
        menu.addAction("Reconfigure", lambda: QProcess.startDetached("labwc", ["-r"]))
        menu.addAction("Exit", lambda: QProcess.startDetached("nscde-wayland-logout"))

        global_pos = button.mapToGlobal(QPoint(0, button.height()))
        menu.exec(global_pos)

    def _on_iconify_clicked(self):
        """Handle iconify button click - minimize panel"""
        self.showMinimized()

    def _on_launcher_clicked(self, tooltip, button):
        """Handle launcher button click - show subpanel"""
        # Map tooltip to subpanel key
        subpanel_map = {
            "Applications (L1)": "start-here",
            "Terminal (L2)": "utilities-terminal",
            "Home (L3)": "start-here",
            "Apps (L4)": "start-here",
            "Clock (L5)": "start-here",
            "Print (R6)": "start-here",
            "Style (R7)": "start-here",
            "Apps (R8)": "start-here",
            "Multimedia (R9)": "start-here",
            "Help (R10)": "start-here",
        }

        subpanel_key = subpanel_map.get(tooltip, "start-here")

        if self.subpanel and self.subpanel.isVisible():
            self.subpanel.reject()

        subpanel_def = SUBPANELS.get(subpanel_key, SUBPANELS["start-here"])
        self.subpanel = SubPanel(self, subpanel_def["items"], subpanel_def["title"])
        global_pos = button.mapToGlobal(QPoint(0, 0))
        self.subpanel.popup_at(global_pos)

    def _on_icon_clicked(self, tooltip):
        """Handle icon button click"""
        print(f"Icon clicked: {tooltip}", file=sys.stderr)

    def _on_lock_clicked(self):
        """Handle lock button click"""
        if QProcess.startDetached("nscde-wayland-lock"):
            return
        # Fallback: try common screen lockers directly
        for cmd in ["swaylock", "waylock", "gtklock"]:
            if QProcess.startDetached(cmd):
                return
        print("No screen locker found", file=sys.stderr)

    def _on_pgm_clicked(self):
        """Handle PGM (Page Manager) button click - show workspace menu"""
        try:
            QProcess.startDetached("labwc", ["-r"])
        except Exception as e:
            print(f"Error showing page manager: {e}", file=sys.stderr)

    def _on_lite_clicked(self):
        """Handle lite button click - show system load info"""
        try:
            QProcess.startDetached("nscde-wayland-run", ["foot", "-e", "htop"])
        except Exception as e:
            print(f"Error opening htop: {e}", file=sys.stderr)

    def _on_exit_clicked(self):
        """Handle exit button click - show logout dialog"""
        try:
            QProcess.startDetached("nscde-wayland-logout")
        except Exception as e:
            print(f"Error launching logout dialog: {e}", file=sys.stderr)

    def _on_workspace_clicked(self, workspace_num):
        """Handle workspace button click"""
        workspace_name = f"ws{workspace_num + 1}"
        # Try wlrctl for workspace switching, fallback to labwc reconfigure
        try:
            if QProcess.startDetached("wlrctl", ["desktop", workspace_name]):
                pass
            else:
                # wlrctl not available, update visual state only
                pass
        except Exception:
            pass

        self.current_workspace = workspace_num
        for i, btn in enumerate(self.workspace_buttons):
            btn.setChecked(i == workspace_num)

    def _update_clock(self):
        """Update clock display in WSM area"""
        # Clock is now shown via the WSM widget area
        # We update a clock label if it exists
        pass

    def _update_taskbar(self):
        """Update taskbar - scan for running windows"""
        # Taskbar functionality: scan /proc for GUI apps
        # This is a placeholder for future wlr-foreign-toplevel support
        pass


# Subpanel definitions (CDE-style)
SUBPANELS = {
    "utilities-terminal": {
        "title": "Terminal Tools",
        "items": [
            {"name": "Terminal", "icon": "utilities-terminal", "cmd": ["nscde-wayland-run", "foot"]},
            {"name": "Screenshot Area", "icon": "camera-photo", "cmd": ["nscde-wayland-screenshot", "area"]},
            {"name": "Screenshot Full", "icon": "camera-photo", "cmd": ["nscde-wayland-screenshot", "full"]},
        ]
    },
    "system-file-manager": {
        "title": "File Tools",
        "items": [
            {"name": "File Manager", "icon": "system-file-manager", "cmd": ["nscde-wayland-run", "app", "pcmanfm-qt"]},
            {"name": "Disks", "icon": "drive-harddisk", "cmd": ["nscde-wayland-run", "app", "gnome-disks"]},
        ]
    },
    "start-here": {
        "title": "NsCDE Menu",
        "items": [
            {"name": "Run...", "icon": "system-run", "cmd": ["nscde-wayland-run", "fuzzel"]},
            {"name": "Terminal", "icon": "utilities-terminal", "cmd": ["nscde-wayland-run", "foot"]},
            {"name": "File Manager", "icon": "system-file-manager", "cmd": ["nscde-wayland-run", "app", "pcmanfm-qt"]},
            {"name": "Settings", "icon": "preferences-system", "cmd": ["nscde-wayland-run", "app", "nwg-look"]},
            {"name": "Screenshot", "icon": "camera-photo", "cmd": ["nscde-wayland-screenshot", "area"]},
            {"name": "Reconfigure", "icon": "view-refresh", "cmd": ["labwc", "-r"]},
            {"name": "Exit", "icon": "system-log-out", "cmd": ["nscde-wayland-logout"]},
        ]
    },
}


def main():
    parser = argparse.ArgumentParser(description='NsCDE CDE-style panel (PyQt6)')
    parser.add_argument('--palette', help='Path to CDE palette file')
    parser.add_argument('--position', choices=['top', 'bottom'], default='bottom',
                        help='Panel position (default: bottom)')
    args = parser.parse_args()

    # Enable High DPI
    QApplication.setHighDpiScaleFactorRoundingPolicy(
        Qt.HighDpiScaleFactorRoundingPolicy.PassThrough
    )

    app = QApplication(sys.argv)
    app.setApplicationName("nscde-panel")
    app.setDesktopFileName("nscde-panel")

    # Handle SIGINT/SIGTERM gracefully
    signal.signal(signal.SIGINT, lambda s, f: app.quit())
    signal.signal(signal.SIGTERM, lambda s, f: app.quit())

    panel = CDEPanel(palette_file=args.palette, position=args.position)
    panel.show()

    panel.raise_()

    sys.exit(app.exec())


if __name__ == '__main__':
    main()