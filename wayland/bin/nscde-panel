#!/usr/bin/env python3
"""
nscde-panel - Native CDE-style front panel for NsCDE Wayland
Uses PyQt6 for Wayland panel implementation.

Layout matches NsCDE FrontPanel.fvwm3.fvwmconf:
  [LeftHandle] [LeftLaunchers] [LeftIcons] [Center: Lock+WSM+Lite+Exit] [RightLaunchers] [RightIcons] [RightHandle]

Usage:
  nscde-panel [--palette PALETTE.dp] [--position top|bottom]
"""

import sys
import os
import signal
import argparse

# Add lib directory to path (source tree or installed)
_script_dir = os.path.dirname(os.path.abspath(__file__))
_source_lib = os.path.join(os.path.dirname(_script_dir), "lib")
_installed_lib = "/usr/share/nscde-wayland/lib"
sys.path.insert(0, _source_lib if os.path.isdir(_source_lib) else _installed_lib)

from nscde_cde import find_default_palette, load_palette_colors, get_icon_path

from PyQt6.QtWidgets import (
    QApplication, QWidget, QHBoxLayout, QVBoxLayout,
    QPushButton, QLabel, QDialog, QMenu, QFrame
)
from PyQt6.QtCore import (
    Qt, QTimer, QProcess, QPoint, QSize
)
from PyQt6.QtGui import (
    QIcon, QScreen, QFont, QPixmap
)

# Constants - matching NsCDE FrontPanel.fvwm3.fvwmconf
# FvwmButtons BoxSize fixed: 1格 = 1像素
PANEL_HEIGHT = 79          # 面板总高度 79 像素
HANDLE_WIDTH = 21          # 左右把手容器宽度 21 像素
SIDE_W = 315               # 每侧(launcher+icon)总宽 = 5 × 63 像素
LAUNCHER_H = 16            # launcher 容器高度 16 像素
ICON_H = 62                # icon 容器高度 62 像素
LAUNCHER_BTN_W = 63        # 单个 launcher 按钮宽 63 像素
LAUNCHER_BTN_H = 16        # 单个 launcher 按钮高 16 像素
ICON_CELL_W = 63           # 图标格子宽 63 像素
ICON_CELL_H = 60           # 图标格子高 60 像素（Frame 1 边框内部）
ICON_SIZE = 48             # 图标实际像素 48×48
CENTER_W = 343             # 中心 WSM 容器宽度
CENTER_H = 78              # 中心 WSM 容器高度
NUM_BTNS = 5               # 每侧按钮数
PANEL_TOTAL_W = 21 + 315 + 343 + 315 + 21  # = 1015 像素
CENTER_BTN_W = 44          # Lock/Lite/Exit 按钮宽 (2格)
CENTER_BTN_H = 39          # Lock/Lite/Exit 按钮高 (1格)
CLOCK_FORMAT = "%H:%M"
DATE_FORMAT = "%Y-%m-%d"
NUM_WORKSPACES = 4

def build_cde_stylesheet(colors):
    """Build CDE 3D border stylesheet from palette colors.
    Panel uses Colorset 23 (warm beige), buttons use Colorset 1 (gray).
    """
    return f"""
    /* === Panel window (CS1 border like FVWM Window Manager) === */
    QWidget#panelWindow {{
        background-color: {colors['bg']};
        border-top: 1px solid {colors['btn_ts']};
        border-left: 1px solid {colors['btn_ts']};
        border-right: 1px solid {colors['btn_bs']};
        border-bottom: 1px solid {colors['btn_bs']};
    }}

    /* === All buttons: CDE 3D raised effect (Colorset 1) === */
    QPushButton {{
        background-color: {colors['btn_bg']};
        color: {colors['btn_fg']};
        border-top: 2px solid {colors['btn_ts']};
        border-left: 2px solid {colors['btn_ts']};
        border-right: 2px solid {colors['btn_bs']};
        border-bottom: 2px solid {colors['btn_bs']};
        border-radius: 0px;
        padding: 2px;
        margin: 0px;
    }}
    QPushButton:hover {{
        background-color: {colors['sel']};
    }}
    QPushButton:pressed {{
        border-top: 2px solid {colors['btn_bs']};
        border-left: 2px solid {colors['btn_bs']};
        border-right: 2px solid {colors['btn_ts']};
        border-bottom: 2px solid {colors['btn_ts']};
    }}

    /* === Labels === */
    QLabel {{
        color: {colors['btn_fg']};
        font: 11px "Noto Sans CJK SC";
        background: transparent;
    }}
    QLabel#clockLabel {{
        font: bold 11px "Noto Sans CJK SC";
        padding: 0 6px;
    }}

    /* === Taskbar buttons === */
    QPushButton#taskbarBtn {{
        min-width: 80px;
        padding: 2px 6px;
        font: 11px "Noto Sans CJK SC";
    }}
    QPushButton#taskbarBtn:checked {{
        border-top: 2px solid {colors['btn_bs']};
        border-left: 2px solid {colors['btn_bs']};
        border-right: 2px solid {colors['btn_ts']};
        border-bottom: 2px solid {colors['btn_ts']};
        background-color: {colors['sel']};
    }}

    /* === Workspace buttons === */
    QPushButton#workspaceBtn {{
        min-width: 24px;
        padding: 2px 4px;
        font: bold 11px "Noto Sans CJK SC";
    }}
    QPushButton#workspaceBtn:checked {{
        border-top: 2px solid {colors['btn_bs']};
        border-left: 2px solid {colors['btn_bs']};
        border-right: 2px solid {colors['btn_ts']};
        border-bottom: 2px solid {colors['btn_ts']};
        background-color: {colors['sel']};
    }}

    /* === Subpanel popup === */
    QDialog {{
        background-color: {colors['bg']};
        border-top: 2px solid {colors['ts']};
        border-left: 2px solid {colors['ts']};
        border-right: 2px solid {colors['bs']};
        border-bottom: 2px solid {colors['bs']};
    }}
    """


# GUI application applications for taskbar tracking
GUI_APPS = {
    "foot": "utilities-terminal",
    "pcmanfm-qt": "system-file-manager",
    "firefox": "firefox",
    "thunderbird": "thunderbird",
    "nautilus": "system-file-manager",
    "dolphin": "system-file-manager",
    "konsole": "utilities-terminal",
    "gnome-terminal": "utilities-terminal",
    "kate": "text-editor",
    "gedit": "text-editor",
    "vim": "text-editor",
    "nvim": "text-editor",
    "code": "visual-studio-code",
    "sublime_text": "text-editor",
}


def enumerate_windows():
    """Enumerate GUI windows by scanning /proc"""
    windows = []
    seen = set()
    try:
        for pid in os.listdir('/proc'):
            if not pid.isdigit():
                continue
            try:
                with open(f'/proc/{pid}/comm') as f:
                    comm = f.read().strip()
                if comm in GUI_APPS and comm not in seen:
                    seen.add(comm)
                    windows.append({
                        "id": pid,
                        "name": comm,
                        "icon": GUI_APPS.get(comm, "application-x-executable")
                    })
            except (PermissionError, FileNotFoundError, ProcessLookupError):
                continue
    except Exception:
        pass
    return windows


class SubPanel(QDialog):
    """CDE-style subpanel popup window"""

    def __init__(self, parent, items, title):
        super().__init__(parent)
        self.setWindowFlags(
            Qt.WindowType.Popup |
            Qt.WindowType.FramelessWindowHint
        )
        self.setFixedWidth(190)

        colors = parent.colors

        self.setStyleSheet(f"""
            QDialog {{
                background-color: {colors['bg']};
                border-top: 2px solid {colors['ts']};
                border-left: 2px solid {colors['ts']};
                border-right: 2px solid {colors['bs']};
                border-bottom: 2px solid {colors['bs']};
            }}
            QLabel#subpanelTitle {{
                color: {colors['btn_fg']};
                font: bold 11px "Noto Sans CJK SC";
                padding: 3px 8px;
            }}
            QLabel#subpanelSep {{
                background-color: {colors['bs']};
            }}
            QPushButton {{
                background-color: {colors['btn_bg']};
                color: {colors['btn_fg']};
                border-top: 2px solid {colors['btn_ts']};
                border-left: 2px solid {colors['btn_ts']};
                border-right: 2px solid {colors['btn_bs']};
                border-bottom: 2px solid {colors['btn_bs']};
                border-radius: 0px;
                padding: 4px 8px;
                margin: 1px;
                min-width: 160px;
                text-align: left;
                font: 11px "Noto Sans CJK SC";
            }}
            QPushButton:hover {{
                background-color: {colors['sel']};
            }}
            QPushButton:pressed {{
                border-top: 2px solid {colors['btn_bs']};
                border-left: 2px solid {colors['btn_bs']};
                border-right: 2px solid {colors['btn_ts']};
                border-bottom: 2px solid {colors['btn_ts']};
            }}
        """)

        vbox = QVBoxLayout(self)
        vbox.setContentsMargins(3, 3, 3, 3)
        vbox.setSpacing(1)

        title_label = QLabel(title)
        title_label.setObjectName("subpanelTitle")
        vbox.addWidget(title_label)

        sep = QLabel()
        sep.setObjectName("subpanelSep")
        sep.setFixedHeight(2)
        vbox.addWidget(sep)

        for item in items:
            btn = QPushButton(item["name"])
            icon = QIcon.fromTheme(item.get("icon", "application-x-executable"))
            if not icon.isNull():
                btn.setIcon(icon)
                btn.setIconSize(QSize(16, 16))
            btn.clicked.connect(lambda checked, cmd=item["cmd"]: self._on_item_clicked(cmd))
            vbox.addWidget(btn)

    def _on_item_clicked(self, cmd):
        try:
            QProcess.startDetached(cmd[0], cmd[1:])
        except Exception as e:
            print(f"Error launching {cmd}: {e}", file=sys.stderr)
        self.accept()

    def popup_at(self, global_pos):
        self.adjustSize()
        x = global_pos.x()
        y = global_pos.y() - self.height() - 4
        self.move(x, y)
        self.exec()


class IconButton(QPushButton):
    """CDE Front Panel icon button with XPM icon.
    Matches original: Colorset 23, Frame 0, PressColorset 24, Padding 0 0
    Icon buttons use panel background (CS23), NO frame border.
    PressColorset 24 approx = sel color (#a0a0a0).
    图标占 63x62 格子，48x48 图标居中
    """

    def __init__(self, parent, xpm_icon_name, tooltip=""):
        super().__init__(parent)
        self._colors = parent.colors
        self._press_bg = parent.colors.get('sel', '#a0a0a0')
        self.setToolTip(tooltip)
        # 整个按钮占 63x62 格子
        self.setFixedSize(ICON_CELL_W, ICON_CELL_H)
        self.setContentsMargins(0, 0, 0, 0)

        # Load XPM icon, 48x48 居中在 63x62 格子中
        icon_path = get_icon_path(xpm_icon_name)
        if icon_path:
            self._pixmap = QPixmap(icon_path)
            if not self._pixmap.isNull():
                self.setIcon(QIcon(self._pixmap))
                self.setIconSize(QSize(ICON_SIZE, ICON_SIZE))

        self._update_style(pressed=False)

    def _update_style(self, pressed=False):
        c = self._colors
        if pressed:
            self.setStyleSheet(f"""
                QPushButton {{
                    background-color: {self._press_bg};
                    border: none;
                    border-radius: 0px;
                    padding: 0px;
                    margin: 0px;
                }}
            """)
        else:
            self.setStyleSheet(f"""
                QPushButton {{
                    background-color: {c['bg']};
                    border: none;
                    border-radius: 0px;
                    padding: 0px;
                    margin: 0px;
                }}
            """)

    def mousePressEvent(self, event):
        self._update_style(pressed=True)
        super().mousePressEvent(event)

    def mouseReleaseEvent(self, event):
        self._update_style(pressed=False)
        super().mouseReleaseEvent(event)


class LauncherButton(QPushButton):
    """CDE Front Panel subpanel launcher button.
    Matches original: 63x16, Frame 1, PressColorset 27, Padding 1 1
    Launcher buttons use CS1 (gray) for 3D border effect.
    PressColorset 27 approx = #b0b0b0.
    """

    def __init__(self, parent, xpm_icon_name, tooltip=""):
        super().__init__(parent)
        self._colors = parent.colors
        self._press_bg = '#b0b0b0'  # PressColorset 27 approximate
        self.setToolTip(tooltip)
        self.setFixedSize(LAUNCHER_BTN_W, LAUNCHER_BTN_H)
        self.setContentsMargins(0, 0, 0, 0)

        # Load XPM icon (小图标 14x14)
        icon_path = get_icon_path(xpm_icon_name)
        if icon_path:
            self._pixmap = QPixmap(icon_path)
            if not self._pixmap.isNull():
                self.setIcon(QIcon(self._pixmap))
                self.setIconSize(QSize(14, 14))

        self._update_style(pressed=False)

    def _update_style(self, pressed=False):
        c = self._colors
        if pressed:
            self.setStyleSheet(f"""
                QPushButton {{
                    background-color: {self._press_bg};
                    border-top: 1px solid {c['btn_bs']};
                    border-left: 1px solid {c['btn_bs']};
                    border-right: 1px solid {c['btn_ts']};
                    border-bottom: 1px solid {c['btn_ts']};
                    border-radius: 0px;
                    padding: 1px;
                    margin: 0px;
                }}
            """)
        else:
            self.setStyleSheet(f"""
                QPushButton {{
                    background-color: {c['btn_bg']};
                    border-top: 1px solid {c['btn_ts']};
                    border-left: 1px solid {c['btn_ts']};
                    border-right: 1px solid {c['btn_bs']};
                    border-bottom: 1px solid {c['btn_bs']};
                    border-radius: 0px;
                    padding: 1px;
                    margin: 0px;
                }}
            """)

    def mousePressEvent(self, event):
        self._update_style(pressed=True)
        super().mousePressEvent(event)

    def mouseReleaseEvent(self, event):
        self._update_style(pressed=False)
        super().mouseReleaseEvent(event)


class CenterButton(QPushButton):
    """CDE Front Panel center button (Lock, Lite, Exit).
    Matches original: 2x1 格 ≈ 44x39 像素, Frame 0, Colorset 23, PressColorset 25
    Center buttons use panel bg (CS23), NO frame border.
    叠在 WSM 主区域上方
