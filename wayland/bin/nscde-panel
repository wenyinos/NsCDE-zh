#!/usr/bin/env python3
"""
nscde-panel - Native CDE-style front panel for NsCDE Wayland
Uses GTK3 + gtk-layer-shell for Wayland panel implementation.

Usage:
  nscde-panel [--palette PALETTE.dp] [--position top|bottom]
"""

import sys
import os
import signal
import argparse
import subprocess
import json
from datetime import datetime

import gi
gi.require_version('Gtk', '3.0')
gi.require_version('GtkLayerShell', '0.1')
from gi.repository import Gtk, Gdk, GLib, GtkLayerShell

# Constants
PANEL_HEIGHT = 58
ICON_SIZE = 22
BUTTON_PADDING = 4
CLOCK_FORMAT = "%H:%M"
DATE_FORMAT = "%Y-%m-%d"
NUM_WORKSPACES = 4

# Subpanel definitions (CDE-style)
SUBPANELS = {
    "utilities-terminal": {
        "title": "Terminal Tools",
        "items": [
            {"name": "Terminal", "icon": "utilities-terminal", "cmd": ["nscde-wayland-run", "foot"]},
            {"name": "Screenshot Area", "icon": "camera-photo", "cmd": ["nscde-wayland-screenshot", "area"]},
            {"name": "Screenshot Full", "icon": "camera-photo", "cmd": ["nscde-wayland-screenshot", "full"]},
        ]
    },
    "system-file-manager": {
        "title": "File Tools",
        "items": [
            {"name": "File Manager", "icon": "system-file-manager", "cmd": ["nscde-wayland-run", "app", "pcmanfm-qt"]},
            {"name": "Disks", "icon": "drive-harddisk", "cmd": ["nscde-wayland-run", "app", "gnome-disks"]},
        ]
    },
    "start-here": {
        "title": "NsCDE Menu",
        "items": [
            {"name": "Run...", "icon": "system-run", "cmd": ["nscde-wayland-run", "fuzzel"]},
            {"name": "Terminal", "icon": "utilities-terminal", "cmd": ["nscde-wayland-run", "foot"]},
            {"name": "File Manager", "icon": "system-file-manager", "cmd": ["nscde-wayland-run", "app", "pcmanfm-qt"]},
            {"name": "Settings", "icon": "preferences-system", "cmd": ["nscde-wayland-run", "app", "nwg-look"]},
            {"name": "Screenshot", "icon": "camera-photo", "cmd": ["nscde-wayland-screenshot", "area"]},
            {"name": "Reconfigure", "icon": "view-refresh", "cmd": ["nscde-wayland-run", "labwc", "-a", "Reconfigure"]},
            {"name": "Exit", "icon": "system-log-out", "cmd": ["nscde-wayland-run", "labwc", "-a", "Exit"]},
        ]
    },
}


class SubPanelWindow(Gtk.Window):
    """CDE-style subpanel popup window"""
    
    def __init__(self, parent_panel, items, title, position):
        super().__init__(type=Gtk.WindowType.TOPLEVEL)
        self.parent_panel = parent_panel
        self.set_title(title)
        self.set_decorated(False)
        self.set_resizable(False)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)
        
        # Initialize layer shell for popup
        GtkLayerShell.init_for_window(self)
        GtkLayerShell.set_layer(self, GtkLayerShell.Layer.OVERLAY)
        GtkLayerShell.set_anchor(self, GtkLayerShell.Edge.BOTTOM, True)
        GtkLayerShell.set_keyboard_mode(self, GtkLayerShell.KeyboardMode.ON_DEMAND)
        
        # Apply CDE style
        self._apply_style()
        
        # Build UI
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
        vbox.set_margin_top(4)
        vbox.set_margin_bottom(4)
        vbox.set_margin_left(4)
        vbox.set_margin_right(4)
        
        # Title label
        title_label = Gtk.Label(label=title)
        title_label.get_style_context().add_class("subpanel-title")
        vbox.pack_start(title_label, False, False, 2)
        
        sep = Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL)
        vbox.pack_start(sep, False, False, 2)
        
        # Menu items
        for item in items:
            btn = self._create_menu_button(item)
            vbox.pack_start(btn, False, False, 0)
        
        self.add(vbox)
        self.show_all()
        
        # Position window
        self._position_window(position)
    
    def _apply_style(self):
        """Apply CDE style to subpanel"""
        colors = self.parent_panel.colors
        css = f"""
        window {{
            background-color: {colors['bg']};
            border-top: 2px solid {colors['ts']};
            border-left: 2px solid {colors['ts']};
            border-right: 2px solid {colors['bs']};
            border-bottom: 2px solid {colors['bs']};
        }}
        .subpanel-title {{
            font: bold 12px Sans;
            color: {colors['fg']};
            padding: 2px 8px;
        }}
        button {{
            background-color: {colors['btn_bg']};
            color: {colors['fg']};
            border-top: 2px solid {colors['btn_ts']};
            border-left: 2px solid {colors['btn_ts']};
            border-right: 2px solid {colors['btn_bs']};
            border-bottom: 2px solid {colors['btn_bs']};
            border-radius: 0;
            padding: 4px 8px;
            margin: 1px;
            min-width: 160px;
        }}
        button:hover {{ background-color: {colors['sel']}; }}
        button:active {{
            border-top: 2px solid {colors['btn_bs']};
            border-left: 2px solid {colors['btn_bs']};
            border-right: 2px solid {colors['btn_ts']};
            border-bottom: 2px solid {colors['btn_ts']};
        }}
        """
        style_provider = Gtk.CssProvider()
        style_provider.load_from_data(css.encode())
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), style_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )
    
    def _create_menu_button(self, item):
        """Create a menu button for subpanel item"""
        btn = Gtk.Button()
        hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        
        try:
            icon = Gtk.Image.new_from_icon_name(item.get("icon", "application-x-executable"), Gtk.IconSize.MENU)
            icon.set_pixel_size(16)
            hbox.pack_start(icon, False, False, 0)
        except:
            pass
        
        label = Gtk.Label(label=item["name"], xalign=0)
        hbox.pack_start(label, True, True, 0)
        
        btn.add(hbox)
        btn.connect("clicked", lambda b: self._on_item_clicked(item))
        return btn
    
    def _on_item_clicked(self, item):
        """Handle menu item click"""
        subprocess.Popen(item["cmd"])
        self.destroy()
    
    def _position_window(self, button_position):
        """Position the subpanel window"""
        # Set margin to position near the button
        GtkLayerShell.set_margin(self, GtkLayerShell.Edge.BOTTOM, PANEL_HEIGHT + 4)
        GtkLayerShell.set_margin(self, GtkLayerShell.Edge.LEFT, button_position)
        self.set_default_size(180, -1)


class NsCDEPanel:
    """Main CDE-style panel class"""
    
    def __init__(self, palette_file=None, position='bottom'):
        self.palette_file = palette_file or self._find_default_palette()
        self.position = position
        self.colors = self._load_palette_colors()
        self.current_workspace = 0
        self.subpanel = None
        
        # Create main window
        self.window = Gtk.Window(type=Gtk.WindowType.TOPLEVEL)
        self.window.set_title("NsCDE Panel")
        self.window.set_default_size(-1, PANEL_HEIGHT)
        self.window.set_decorated(False)
        self.window.set_resizable(False)
        self.window.set_skip_taskbar_hint(True)
        self.window.set_skip_pager_hint(True)
        
        # Initialize layer shell
        self._init_layer_shell()
        
        # Apply CDE style
        self._apply_cde_style()
        
        # Build UI
        self._build_ui()
        
        # Handle signals
        signal.signal(signal.SIGINT, self._on_signal)
        signal.signal(signal.SIGTERM, self._on_signal)
        
    def _find_default_palette(self):
        """Find default palette file"""
        for path in [
            os.path.expanduser("~/.config/nscde-wayland/palette.dp"),
            os.path.expanduser("~/.NsCDE/palettes/GrayScale.dp"),
            "/usr/local/share/nscde-wayland/assets/palettes/GrayScale.dp",
            "/usr/share/nscde-wayland/assets/palettes/GrayScale.dp",
        ]:
            if os.path.exists(path):
                return path
        return None
    
    def _load_palette_colors(self):
        """Load colors from CDE palette file"""
        colors = {
            'bg': '#b8b8b8', 'fg': '#000000', 'ts': '#ffffff',
            'bs': '#5f5f5f', 'sel': '#9fb4cf', 'btn_bg': '#c7c7c7',
            'btn_ts': '#ffffff', 'btn_bs': '#5a5a5a',
        }
        
        if not self.palette_file or not os.path.exists(self.palette_file):
            return colors
        
        try:
            script_dir = os.path.dirname(os.path.abspath(__file__))
            colorcalc = os.path.join(script_dir, 'nscde-wayland-colorcalc')
            if os.path.exists(colorcalc):
                result = subprocess.run(
                    [colorcalc, self.palette_file, '8'],
                    capture_output=True, text=True
                )
                if result.returncode == 0:
                    for line in result.stdout.strip().split('\n'):
                        if '=' in line:
                            key, val = line.split('=', 1)
                            mapping = {
                                'NSCDE_BG_COLOR_5': 'bg', 'NSCDE_FG_COLOR_5': 'fg',
                                'NSCDE_TS_COLOR_5': 'ts', 'NSCDE_BS_COLOR_5': 'bs',
                                'NSCDE_SEL_COLOR_5': 'sel', 'NSCDE_BG_COLOR_1': 'btn_bg',
                                'NSCDE_TS_COLOR_1': 'btn_ts', 'NSCDE_BS_COLOR_1': 'btn_bs',
                            }
                            if key in mapping:
                                colors[mapping[key]] = val
        except Exception as e:
            print(f"Warning: Failed to load palette: {e}", file=sys.stderr)
        return colors
    
    def _init_layer_shell(self):
        """Initialize GtkLayerShell for Wayland panel"""
        GtkLayerShell.init_for_window(self.window)
        GtkLayerShell.set_layer(self.window, GtkLayerShell.Layer.BOTTOM)
        GtkLayerShell.set_anchor(self.window, GtkLayerShell.Edge.BOTTOM, True)
        GtkLayerShell.set_anchor(self.window, GtkLayerShell.Edge.LEFT, True)
        GtkLayerShell.set_anchor(self.window, GtkLayerShell.Edge.RIGHT, True)
        GtkLayerShell.set_exclusive_zone(self.window, PANEL_HEIGHT)
        GtkLayerShell.set_keyboard_mode(self.window, GtkLayerShell.KeyboardMode.NONE)
    
    def _apply_cde_style(self):
        """Apply CDE-style CSS"""
        css = f"""
        window {{
            background-color: {self.colors['bg']};
            border-top: 2px solid {self.colors['ts']};
            border-left: 2px solid {self.colors['ts']};
            border-right: 2px solid {self.colors['bs']};
            border-bottom: 2px solid {self.colors['bs']};
        }}
        button {{
            background-color: {self.colors['btn_bg']};
            color: {self.colors['fg']};
            border-top: 2px solid {self.colors['btn_ts']};
            border-left: 2px solid {self.colors['btn_ts']};
            border-right: 2px solid {self.colors['btn_bs']};
            border-bottom: 2px solid {self.colors['btn_bs']};
            border-radius: 0;
            padding: {BUTTON_PADDING}px {BUTTON_PADDING * 2}px;
            margin: 2px;
            min-width: 28px;
            min-height: 28px;
        }}
        button:hover {{ background-color: {self.colors['sel']}; }}
        button:active {{
            border-top: 2px solid {self.colors['btn_bs']};
            border-left: 2px solid {self.colors['btn_bs']};
            border-right: 2px solid {self.colors['btn_ts']};
            border-bottom: 2px solid {self.colors['btn_ts']};
        }}
        label {{ color: {self.colors['fg']}; font: 12px Sans; }}
        .clock-label {{ font: bold 12px Sans; padding: 0 8px; }}
        .date-label {{ font: 11px Sans; padding: 0 8px; }}
        .taskbar-button {{ min-width: 100px; padding: 3px 8px; }}
        .taskbar-button.active {{ background-color: {self.colors['sel']}; }}
        .workspace-btn {{ min-width: 28px; padding: 2px 6px; }}
        .workspace-btn.active {{ background-color: {self.colors['sel']}; }}
        .tray-icon {{ min-width: 22px; min-height: 22px; padding: 2px; }}
        """
        style_provider = Gtk.CssProvider()
        style_provider.load_from_data(css.encode())
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), style_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )
    
    def _build_ui(self):
        """Build the panel UI"""
        hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=2)
        hbox.set_margin_top(2)
        hbox.set_margin_bottom(2)
        hbox.set_margin_start(4)
        hbox.set_margin_end(4)
        
        # Left: Menu + Launchers with subpanels
        left_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=2)
        for icon, tooltip, subpanel_key in [
            ("start-here", "NsCDE Menu", "start-here"),
            ("utilities-terminal", "Terminal Tools", "utilities-terminal"),
            ("system-file-manager", "File Tools", "system-file-manager"),
        ]:
            btn = self._create_button(icon, tooltip)
            btn.connect("clicked", self._on_launcher_clicked, subpanel_key)
            left_box.pack_start(btn, False, False, 0)
        hbox.pack_start(left_box, False, False, 0)
        
        # Workspace switcher
        ws_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=1)
        for i in range(NUM_WORKSPACES):
            ws_btn = Gtk.Button(label=str(i + 1))
            ws_btn.get_style_context().add_class("workspace-btn")
            if i == self.current_workspace:
                ws_btn.get_style_context().add_class("active")
            ws_btn.connect("clicked", self._on_workspace_clicked, i)
            ws_box.pack_start(ws_btn, False, False, 0)
        hbox.pack_start(ws_box, False, False, 0)
        
        # Center: Taskbar
        self.taskbar_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=2)
        self.taskbar_box.set_hexpand(True)
        hbox.pack_start(self.taskbar_box, True, True, 0)
        
        # Right: Tray + Clock
        right_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=2)
        
        # System tray (placeholder with SNI support)
        self.tray_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=2)
        self._init_system_tray()
        right_box.pack_start(self.tray_box, False, False, 0)
        
        self.date_label = Gtk.Label(label=datetime.now().strftime(DATE_FORMAT))
        self.date_label.get_style_context().add_class("date-label")
        right_box.pack_start(self.date_label, False, False, 0)
        
        self.clock_label = Gtk.Label(label=datetime.now().strftime(CLOCK_FORMAT))
        self.clock_label.get_style_context().add_class("clock-label")
        right_box.pack_start(self.clock_label, False, False, 0)
        
        hbox.pack_start(right_box, False, False, 0)
        self.window.add(hbox)
        
        # Timers
        GLib.timeout_add(1000, self._update_clock)
        GLib.timeout_add(2000, self._update_taskbar)
        self.window.show_all()
    
    def _create_button(self, icon_name, tooltip):
        """Create a CDE-style button with icon"""
        button = Gtk.Button()
        button.set_tooltip_text(tooltip)
        try:
            icon = Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.BUTTON)
            icon.set_pixel_size(ICON_SIZE)
            button.add(icon)
        except:
            button.set_label(tooltip[:8])
        return button
    
    def _on_launcher_clicked(self, button, subpanel_key):
        """Handle launcher button click with subpanel"""
        if subpanel_key in SUBPANELS:
            subpanel_def = SUBPANELS[subpanel_key]
            # Get button position for subpanel placement
            allocation = button.get_allocation()
            position = allocation.x
            
            # Close existing subpanel if any
            if self.subpanel:
                self.subpanel.destroy()
            
            # Create new subpanel
            self.subpanel = SubPanelWindow(
                self, subpanel_def["items"], subpanel_def["title"], position
            )
        else:
            # Fallback to direct command
            subprocess.Popen(["nscde-wayland-run", "fuzzel"])
    
    def _init_system_tray(self):
        """Initialize system tray area"""
        # In Wayland, SNI (StatusNotifierItem) is handled by the compositor
        # We can use a placeholder that watches for tray icons
        # For now, add a simple indicator
        tray_label = Gtk.Label(label="⚙")
        tray_label.get_style_context().add_class("tray-icon")
        tray_label.set_tooltip_text("System Tray (SNI)")
        self.tray_box.pack_start(tray_label, False, False, 0)
    
    def _update_clock(self):
        """Update clock display"""
        now = datetime.now()
        self.clock_label.set_text(now.strftime(CLOCK_FORMAT))
        self.date_label.set_text(now.strftime(DATE_FORMAT))
        return True
    
    def _update_taskbar(self):
        """Update taskbar with current windows"""
        try:
            # Try to get windows from labwc via foreign-toplevel or fallback
            windows = self._get_window_list()
            self._render_taskbar(windows)
        except Exception as e:
            print(f"Taskbar update error: {e}", file=sys.stderr)
        return True
    
    def _get_window_list(self):
        """Get list of current windows (Wayland-compatible)"""
        windows = []
        # Method 1: Try labwc IPC if available
        # Method 2: Fallback - track launched apps
        # Method 3: Use xdotool if Xwayland is available
        try:
            result = subprocess.run(
                ["xdotool", "search", "--onlyvisible", "--name", "."],
                capture_output=True, text=True, timeout=1
            )
            if result.returncode == 0 and result.stdout.strip():
                for win_id in result.stdout.strip().split('\n'):
                    name_result = subprocess.run(
                        ["xdotool", "getwindowname", win_id],
                        capture_output=True, text=True, timeout=1
                    )
                    if name_result.returncode == 0:
                        windows.append({"id": win_id, "name": name_result.stdout.strip()})
        except:
            pass
        return windows
    
    def _render_taskbar(self, windows):
        """Render taskbar buttons for current windows"""
        # Clear existing buttons
        for child in self.taskbar_box.get_children():
            self.taskbar_box.remove(child)
        
        if not windows:
            return
        
        for win in windows:
            btn = Gtk.Button(label=win["name"][:20])
            btn.get_style_context().add_class("taskbar-button")
            btn.connect("clicked", self._on_taskbar_clicked, win)
            self.taskbar_box.pack_start(btn, False, False, 0)
        
        self.taskbar_box.show_all()
    
    def _on_taskbar_clicked(self, button, window_info):
        """Handle taskbar button click - focus window"""
        try:
            subprocess.run(
                ["xdotool", "windowactivate", "--sync", window_info["id"]],
                timeout=1
            )
        except:
            pass
    
    def _on_workspace_clicked(self, button, workspace_num):
        """Handle workspace button click"""
        subprocess.Popen(["nscde-wayland-run", "labwc", "-a", "GoToDesktop", str(workspace_num)])
        self.current_workspace = workspace_num
        for child in button.get_parent().get_children():
            child.get_style_context().remove_class("active")
        button.get_style_context().add_class("active")
    
    def _on_signal(self, signum, frame):
        """Handle termination signal"""
        Gtk.main_quit()
    
    def run(self):
        """Run the panel"""
        Gtk.main()


def main():
    parser = argparse.ArgumentParser(description='NsCDE CDE-style panel')
    parser.add_argument('--palette', help='Path to CDE palette file')
    parser.add_argument('--position', choices=['top', 'bottom'], default='bottom',
                       help='Panel position (default: bottom)')
    args = parser.parse_args()
    panel = NsCDEPanel(palette_file=args.palette, position=args.position)
    panel.run()


if __name__ == '__main__':
    main()
